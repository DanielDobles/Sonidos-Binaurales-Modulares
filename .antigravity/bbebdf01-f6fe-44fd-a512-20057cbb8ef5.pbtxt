        }
        lines {
          text: "      ambientFilterRef.current.frequency.setValueAtTime(1200, audioCtx.currentTime);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      ambientFilterRef.current.Q.setValueAtTime(0.5, audioCtx.currentTime);"
