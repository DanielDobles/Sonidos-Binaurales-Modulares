  file_change {
    absolute_path_uri: "file:///app/api/psychoacoustic/route.ts"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { GoogleGenAI, Type } from \"@google/genai\";\nimport { NextRequest, NextResponse } from \"next/server\";\n\n// Initialize the Google GenAI SDK with server secret and telemetry header\nconst ai = new GoogleGenAI({\n  apiKey: process.env.GEMINI_API_KEY,\n  httpOptions: {\n    headers: {\n      \'User-Agent\': \'aistudio-build\',\n    }\n  }\n});\n\nexport async function POST(req: NextRequest) {\n  try {\n    const { prompt } = await req.json();\n\n    if (!prompt || typeof prompt !== \"string\") {\n      return NextResponse.json({ error: \"El prompt es requerido y debe ser texto.\" }, { status: 400 });\n    }\n\n    const systemInstruction = `Eres un experto neurocient\303\255fico especializado en psicoac\303\272stica y terapia de ondas cerebrales. \nTu tarea es dise\303\261ar un programa de tonos binaurales altamente efectivo y personalizado para el estado f\303\255sico/mental descrito por el usuario.\nLos est\303\255mulos binaurales funcionan presentando dos frecuencias ligeramente diferentes a cada o\303\255do, creando un tercer tono de pulso en el cerebro (la diferencia). \nPara evitar que el cerebro se adapte y pierda la sincronizaci\303\263n hemisf\303\251rica (efecto psicoac\303\272stico), sugerimos modulaciones micro-estructurales cada 30 segundos.\n\nGenera una respuesta en JSON estructurado que contenga:\n1. Nombre del programa personalizado.\n2. Explicaci\303\263n neurocient\303\255fica detallada sobre por qu\303\251 este patr\303\263n ac\303\272stico es id\303\263neo y c\303\263mo actuar\303\241 en su cerebro.\n3. Frecuencia portadora base recomendada en Hz (entre 100 Hz y 300 Hz, que son agradables e id\303\263neas para inducir arrastre de frecuencias).\n4. Frecuencia de pulso binaural base recomendada (entre 1 Hz y 45 Hz).\n   - Ondas Delta (1-4 Hz): Sue\303\261o profundo, curaci\303\263n.\n   - Ondas Theta (4-8 Hz): Meditaci\303\263n, creatividad, sue\303\261o ligero, hipnagogia.\n   - Ondas Alfa (8-12 Hz): Relajaci\303\263n, super-aprendizaje, calma.\n   - Ondas Beta (12-30 Hz): Enfoque, procesamiento de datos, resoluci\303\263n de problemas.\n   - Ondas Gamma (30-45 Hz): Procesamiento cognitivo de alto nivel, flash de lucidez.\n5. Un array de 6 fases secuenciales o pasos de micro-modulaci\303\263n (cada paso dura 30 segundos). Para cada paso, proporciona un desplazamiento de frecuencia portadora (ej. de -12 a +12Hz) y de frecuencia del pulso (ej. de -1.5 a +1.5Hz). Esto mantendr\303\241 al cerebro activo en su recepci\303\263n ac\303\272stica sin habituaci\303\263n.\n6. Fondo ambiental sugerido (ruido rosa, ruido marr\303\263n, lluvia, viento c\303\263smico, etc.).\n\nToda la respuesta debe redactarse en espa\303\261ol elegante y con fundamentos cient\303\255ficos reales.`;\n\n    const response = await ai.models.generateContent({\n      model: \"gemini-3.5-flash\",\n      contents: `Dise\303\261a un programa binaural modular potente para: \"${prompt}\"`,\n      config: {\n        systemInstruction,\n        responseMimeType: \"application/json\",\n        responseSchema: {\n          type: Type.OBJECT,\n          properties: {\n            sessionName: {\n              type: Type.STRING,\n              description: \"Nombre de la sesi\303\263n o del programa psicoac\303\272stico creado.\"\n            },\n            explanation: {\n              type: Type.STRING,\n              description: \"Explicaci\303\263n cient\303\255fica detallada y emp\303\241tica sobre el beneficio cortical del programa.\"\n            },\n            baseCarrierFrequency: {\n              type: Type.NUMBER,\n              description: \"Frecuencia portadora base en Hz, recomendada entre 100 y 300 Hz.\"\n            },\n            binauralBeatFrequency: {\n              type: Type.NUMBER,\n              description: \"Frecuencia del pulso binaural objetivo en Hz, recomendada entre 1 y 45 Hz.\"\n            },\n            autoModulationPattern: {\n              type: Type.ARRAY,\n              description: \"Lista de exactamente 6 variaciones micro-ac\303\272sticas con un intervalo de 30 segundos cada una.\",\n              items: {\n                type: Type.OBJECT,\n                properties: {\n                  stepName: {\n                    type: Type.STRING,\n                    description: \"Nombre descriptivo de la sub-fase (ej. Descarga cortical, Estimulaci\303\263n alfa lenta, etc.).\"\n                  },\n                  carrierOffset: {\n                    type: Type.NUMBER,\n                    description: \"Desplazamiento en Hz de la frecuencia portadora en este paso (ej. de -10 a +10 Hz).\"\n                  },\n                  beatOffset: {\n                    type: Type.NUMBER,\n                    description: \"Desplazamiento en Hz de la frecuencia del pulso en este paso (ej. de -1 a +1 Hz).\"\n                  }\n                },\n                required: [\"stepName\", \"carrierOffset\", \"beatOffset\"]\n              }\n            },\n            suggestedAmbient: {\n              type: Type.STRING,\n              description: \"El tipo de sonido de fondo ideal para acompa\303\261ar este estado.\"\n            }\n          },\n          required: [\n            \"sessionName\",\n            \"explanation\",\n            \"baseCarrierFrequency\",\n            \"binauralBeatFrequency\",\n            \"autoModulationPattern\",\n            \"suggestedAmbient\"\n          ]\n        }\n      }\n    });\n\n    const text = response.text;\n    if (!text) {\n      return NextResponse.json({ error: \"No se recibi\303\263 respuesta v\303\241lida del modelo de IA.\" }, { status: 500 });\n    }\n\n    const data = JSON.parse(text.trim());\n    return NextResponse.json(data);\n  } catch (error: any) {\n    console.error(\"Error en la generaci\303\263n de programa psicoac\303\272stico:\", error);\n    return NextResponse.json({ error: error.message || \"Error interno del servidor en la consulta psicoac\303\272stica.\" }, { status: 500 });\n  }\n}\n"
    }
