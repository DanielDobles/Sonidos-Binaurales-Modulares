        }
        lines {
          text: "      name: \'Ondas Beta\', "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      range: \'12 - 30 Hz\', "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      beatFreq: 18.0, "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      carrierFreq: 220, "
