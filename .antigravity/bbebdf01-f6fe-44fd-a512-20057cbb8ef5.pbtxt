        }
        lines {
          text: "      ctx.stroke();"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      // Small HUD overlay texts demonstrating live frequency offsets with strict band clamping"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
