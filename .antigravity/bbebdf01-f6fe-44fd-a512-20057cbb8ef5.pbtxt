        }
        lines {
          text: "      ambientLFORef.current = lfo;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    } else if (ambientFilterRef.current) {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      // Direct pass filter with fixed comfortable static"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      ambientFilterRef.current.type = \'lowpass\';"
