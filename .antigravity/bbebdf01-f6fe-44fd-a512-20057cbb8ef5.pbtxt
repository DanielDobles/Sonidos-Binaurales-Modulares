    instruction: "Set the initial state of ambientType to \'none\' and make initial modulationSteps offsets a bit more subtle for Alpha (10Hz)."
    replacement_infos {
      original_chunk {
        target_content: "  // --- REACT STATES ---\n  const [isPlaying, setIsPlaying] = useState<boolean>(false);\n  const [carrierFreq, setCarrierFreq] = useState<number>(180); // Hz\n  const [binauralBeatFreq, setBinauralBeatFreq] = useState<number>(10); // Hz (Alpha)\n  const [masterVolume, setMasterVolume] = useState<number>(0.5); // 0 - 1\n  const [ambientVolume, setAmbientVolume] = useState<number>(0.3); // 0 - 1\n  const [ambientType, setAmbientType] = useState<string>(\'cosmic\'); // \'none\' | \'pink\' | \'brown\' | \'cosmic\'\n  const [waveType, setWaveType] = useState<\'sine\' | \'triangle\'>(\'sine\');\n  \n  // Modulator parameters\n  const [isModulationEnabled, setIsModulationEnabled] = useState<boolean>(true);\n  const [currentModStep, setCurrentModStep] = useState<number>(0);\n  const [secondsRemaining, setSecondsRemaining] = useState<number>(30);\n  \n  // AI program states\n  const [aiPrompt, setAiPrompt] = useState<string>(\'\');\n  const [isAiLoading, setIsAiLoading] = useState<boolean>(false);\n  const [aiError, setAiError] = useState<string | null>(null);\n  const [activeProgramName, setActiveProgramName] = useState<string>(\'Ondas de Calma Inicial\');\n  const [aiExplanation, setAiExplanation] = useState<string>(\'Esta sesi\303\263n inicial combina ondas portadoras bajas de 180Hz con un pulso de 10Hz en el rango Alfa para sincronizar tus hemisferios y disolver el estr\303\251s.\');\n  \n  // Adaptive modulation pattern\n  const [modulationSteps, setModulationSteps] = useState<ModulationStep[]>([\n    { stepName: \'Sincronizaci\303\263n Inicial\', carrierOffset: 0, beatOffset: 0 },\n    { stepName: \'Activaci\303\263n Cortical\', carrierOffset: 8, beatOffset: 0.5 },\n    { stepName: \'Desplazamiento de Fase\', carrierOffset: -6, beatOffset: -0.5 },\n    { stepName: \'Estabilizaci\303\263n Hemisf\303\251rica\', carrierOffset: 12, beatOffset: 1.0 },\n    { stepName: \'Inversi\303\263n Psicoac\303\272stica\', carrierOffset: -10, beatOffset: -1.0 },\n    { stepName: \'Armonizaci\303\263n Integrada\', carrierOffset: 4, beatOffset: 0 }\n  ]);"
