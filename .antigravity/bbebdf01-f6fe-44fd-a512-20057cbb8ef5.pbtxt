  file_change {
    absolute_path_uri: "file:///components/BinauralBeatsApp.tsx"
    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "    // Disconnect pipelines\n    if (masterGainRef.current) {\n      masterGainRef.current.disconnect();\n      masterGainRef.current = null;\n    }\n    setIsPlaying(false);\n  };\n\n  // --- REACT ACTIONS ON PLAY & PARAM CHANGE ---\n\n  // Handle active playback frequency updating\n  useEffect(() => {\n    if (isPlaying) {\n      updateFrequencies(carrierFreq, binauralBeatFreq);\n    }\n  }, [isPlaying, carrierFreq, binauralBeatFreq, updateFrequencies, currentModStep, isModulationEnabled]);\n\n  // Restart ambient noise when ambient preferences change\n  useEffect(() => {\n    configureAmbientNode();\n  }, [isPlaying, ambientType, configureAmbientNode]);\n\n  // Adjust volume levels dynamically\n  useEffect(() => {\n    const audioCtx = audioCtxRef.current;\n    if (audioCtx && isPlaying) {\n      if (masterGainRef.current) {\n        masterGainRef.current.gain.setTargetAtTime(masterVolume, audioCtx.currentTime, 0.1);\n      }\n      if (ambientGainRef.current) {\n        ambientGainRef.current.gain.setTargetAtTime(ambientVolume * 0.4, audioCtx.currentTime, 0.1);\n      }\n    }\n  }, [masterVolume, ambientVolume, isPlaying]);\n\n  // Handle wave type selector adjustments\n  useEffect(() => {\n    if (isPlaying && oscLeftRef.current && oscRightRef.current) {\n      oscLeftRef.current.type = waveType;\n      oscRightRef.current.type = waveType;\n    }\n  }, [waveType, isPlaying]);\n\n  // Cleanup on unmount\n  useEffect(() => {\n    return () => {\n      stopSoundEngine();\n      if (animationFrameIdRef.current) {\n        cancelAnimationFrame(animationFrameIdRef.current);\n      }\n    };\n  }, []);\n\n  // --- MODULAR TIMELINE TIMER ENGINE (30s) ---\n  useEffect(() => {\n    if (!isPlaying || !isModulationEnabled) {\n      setSecondsRemaining(30);\n      return;\n    }\n\n    const interval = setInterval(() => {\n      setSecondsRemaining((prev) => {\n        if (prev <= 1) {\n          // Time\'s up! Rotate to next phase step seamlessly.\n          setCurrentModStep((step) => {\n            const nextStep = (step + 1) % modulationSteps.length;\n            return nextStep;\n          });\n          return 30; // Reset countdown\n        }\n        return prev - 1;\n      });\n    }, 1000);\n\n    return () => clearInterval(interval);\n  }, [isPlaying, isModulationEnabled, modulationSteps.length]);\n\n  // If modulation changes, trigger a quick refresh on frequencies\n  useEffect(() => {\n    if (isPlaying) {\n      updateFrequencies(carrierFreq, binauralBeatFreq);\n    }\n  }, [currentModStep, isPlaying, updateFrequencies, carrierFreq, binauralBeatFreq]);\n\n  // --- RECHART DRAWING REALTIME VISUALIZER (Stereo ribbon & entrainment breathe mandala) ---\n  const renderVisuals = useCallback(() => {\n    const canvas = canvasRef.current;\n    if (!canvas) return;\n    const ctx = canvas.getContext(\'2d\');\n    if (!ctx) return;\n\n    const width = canvas.width;\n    const height = canvas.height;\n\n    const analyserL = analyserLeftRef.current;\n    const analyserR = analyserRightRef.current;\n\n    const bufferLengthL = analyserL ? analyserL.frequencyBinCount : 256;\n    const bufferLengthR = analyserR ? analyserR.frequencyBinCount : 256;\n\n    const dataArrayL = new Uint8Array(bufferLengthL);\n    const dataArrayR = new Uint8Array(bufferLengthR);\n\n    // Fetch array data on active playing\n    if (isPlaying && analyserL && analyserR) {\n      analyserL.getByteTimeDomainData(dataArrayL);\n      analyserR.getByteTimeDomainData(dataArrayR);\n    } else {\n      // Populate static placeholder baseline waves when muted\n      for (let i = 0; i < bufferLengthL; i++) {\n        dataArrayL[i] = 128 + Math.sin(i * 0.08) * 15;\n        dataArrayR[i] = 128 + Math.sin(i * 0.08 + Math.PI / 3) * 15;\n      }\n    }\n\n    // Solid deep cosmic void background with slight dark grid lines\n    ctx.fillStyle = \'rgba(15, 23, 42, 0.2)\'; // trailing effect\n    ctx.fillRect(0, 0, width, height);\n\n    // Draw audio visual grid\n    ctx.strokeStyle = \'rgba(30, 41, 59, 0.4)\';\n    ctx.lineWidth = 1;\n    for (let i = 50; i < width; i += 100) {\n      ctx.beginPath();\n      ctx.moveTo(i, 0);\n      ctx.lineTo(i, height);\n      ctx.stroke();\n    }\n    for (let j = 40; j < height; j += 80) {\n      ctx.beginPath();\n      ctx.moveTo(0, j);\n      ctx.lineTo(width, j);\n      ctx.stroke();\n    }\n\n    // DRAW SACRED ENTRAINMENT PULSATING MANDALA IN THE CENTER\n    // The respiration speed map smoothly to current binaural beat frequency\n    const timeSec = Date.now() / 1000;\n    const pulsationRatio = 0.5 + 0.5 * Math.sin(timeSec * binauralBeatFreq * Math.PI * 0.4); \n    const breatheRadius = 38 + pulsationRatio * 18; // Oscillates radially\n\n    const centerX = width / 2;\n    const centerY = height / 2;\n\n    // Glowing cosmic background aura\n    const glowGradient = ctx.createRadialGradient(centerX, centerY, 5, centerX, centerY, breatheRadius * 2);\n    glowGradient.addColorStop(0, \'rgba(124, 58, 237, 0.15)\'); // Violent aura\n    glowGradient.addColorStop(1, \'rgba(0, 0, 0, 0)\');\n    ctx.fillStyle = glowGradient;\n    ctx.beginPath();\n    ctx.arc(centerX, centerY, breatheRadius * 2, 0, Math.PI * 2);\n    ctx.fill();\n\n    // Sacred Geometry: Hexagram pattern\n    ctx.strokeStyle = `rgba(168, 85, 247, ${isPlaying ? \'0.45\' : \'0.25\'})`;\n    ctx.lineWidth = 2;\n    ctx.shadowBlur = isPlaying ? 15 : 4;\n    ctx.shadowColor = \'#06b6d4\';\n\n    ctx.beginPath();\n    for (let k = 0; k < 6; k++) {\n      const angle = (k * Math.PI) / 3 + timeSec * 0.12; // slow rot\n      const px = centerX + Math.cos(angle) * breatheRadius;\n      const py = centerY + Math.sin(angle) * breatheRadius;\n      if (k === 0) ctx.moveTo(px, py);\n      else ctx.lineTo(px, py);\n    }\n    ctx.closePath();\n    ctx.stroke();\n\n    // Secondary inverted interlaced triangle\n    ctx.strokeStyle = \'rgba(6, 182, 212, 0.4)\';\n    ctx.beginPath();\n    for (let k = 0; k < 6; k++) {\n      const angle = (k * Math.PI) / 3 + Math.PI / 6 - timeSec * 0.12;\n      const px = centerX + Math.cos(angle) * (breatheRadius * 0.7);\n      const py = centerY + Math.sin(angle) * (breatheRadius * 0.7);\n      if (k === 0) ctx.moveTo(px, py);\n      else ctx.lineTo(px, py);\n    }\n    ctx.closePath();\n    ctx.stroke();\n\n    // Reset simple shadows\n    ctx.shadowBlur = 0;\n\n    // DRAW LEFT CHANNEL WAVE (Emerald/Teal Green ribbon at the top/full)\n    ctx.lineWidth = 2.5;\n    ctx.strokeStyle = \'rgba(16, 185, 129, 0.85)\'; // Green Emerald Left\n    ctx.beginPath();\n    \n    let sliceWidthL = width / bufferLengthL;\n    let xL = 0;\n\n    for (let i = 0; i < bufferLengthL; i++) {\n      const v = dataArrayL[i] / 128.0; // normalised around 1.0\n      // Map wave domain slightly high on the center\n      const y = (v * height) / 2 + (Math.sin(i * 0.05 + timeSec * 2) * (isPlaying ? 8 : 2)); \n\n      if (i === 0) {\n        ctx.moveTo(xL, y);\n      } else {\n        ctx.lineTo(xL, y);\n      }\n      xL += sliceWidthL;\n    }\n    ctx.stroke();\n\n    // DRAW RIGHT CHANNEL WAVE (Indigo/Violet ribbon overlaying)\n    ctx.lineWidth = 2.5;\n    ctx.strokeStyle = \'rgba(99, 102, 241, 0.85)\'; // Indigo Right\n    ctx.beginPath();\n\n    let sliceWidthR = width / bufferLengthR;\n    let xR = 0;\n\n    for (let i = 0; i < bufferLengthR; i++) {\n      const v = dataArrayR[i] / 128.0;\n      // Slightly different wave shift to demonstrate offset visually\n      const y = (v * height) / 2 + (Math.sin(i * 0.05 - timeSec * 2) * (isPlaying ? -8 : -2)); \n\n      if (i === 0) {\n        ctx.moveTo(xR, y);\n      } else {\n        ctx.lineTo(xR, y);\n      }\n      xR += sliceWidthR;\n    }\n    ctx.stroke();\n\n    // Small HUD overlay texts demonstrating live frequency offsets\n    ctx.fillStyle = \'rgba(255, 255, 255, 0.65)\';\n    ctx.font = \'10px monospace\';\n    // Frequency indicator L and R in real-time\n    const activeMod = isModulationEnabled ? modulationSteps[currentModStep] : null;\n    const carrierOffset = activeMod ? activeMod.carrierOffset : 0;\n    const beatOffset = activeMod ? activeMod.beatOffset : 0;\n\n    const currentBase = carrierFreq + carrierOffset;\n    const currentPulse = binauralBeatFreq + beatOffset;\n\n    const freqL = (currentBase - currentPulse / 2).toFixed(1);\n    const freqR = (currentBase + currentPulse / 2).toFixed(1);\n\n    ctx.fillText(`CANAL IZQ: ${freqL} Hz`, 15, 25);\n    ctx.fillText(`CANAL DER: ${freqR} Hz`, width - 150, 25);\n    ctx.fillText(`DIFERENCIA: ${currentPulse.toFixed(1)} Hz (ARR\303\201STRE CORTICAL)`, centerX - 110, height - 15);\n\n    animationFrameIdRef.current = requestAnimationFrame(renderVisuals);\n  }, [isPlaying, binauralBeatFreq, carrierFreq, currentModStep, isModulationEnabled, modulationSteps]);\n\n  // Setup loop for animation\n  useEffect(() => {\n    animationFrameIdRef.current = requestAnimationFrame(renderVisuals);\n    return () => {\n      if (animationFrameIdRef.current) {\n        cancelAnimationFrame(animationFrameIdRef.current);\n      }\n    };\n  }, [renderVisuals]);\n\n  // --- GEMINI SERVICE REQUESTS ---"
      replacement_content: "    // Disconnect pipelines\n    if (masterGainRef.current) {\n      masterGainRef.current.disconnect();\n      masterGainRef.current = null;\n    }\n    setIsPlaying(false);\n    setSecondsRemaining(30);\n  };\n\n  // --- REACT ACTIONS ON PLAY & PARAM CHANGE ---\n\n  // Handle active playback frequency updating\n  useEffect(() => {\n    if (isPlaying) {\n      updateFrequencies(carrierFreq, binauralBeatFreq);\n    }\n  }, [isPlaying, carrierFreq, binauralBeatFreq, updateFrequencies, currentModStep, isModulationEnabled]);\n\n  // Restart ambient noise when ambient preferences change\n  useEffect(() => {\n    configureAmbientNode();\n  }, [isPlaying, ambientType, configureAmbientNode]);\n\n  // Adjust volume levels dynamically\n  useEffect(() => {\n    const audioCtx = audioCtxRef.current;\n    if (audioCtx && isPlaying) {\n      if (masterGainRef.current) {\n        masterGainRef.current.gain.setTargetAtTime(masterVolume, audioCtx.currentTime, 0.1);\n      }\n      if (ambientGainRef.current) {\n        ambientGainRef.current.gain.setTargetAtTime(ambientVolume * 0.4, audioCtx.currentTime, 0.1);\n      }\n    }\n  }, [masterVolume, ambientVolume, isPlaying]);\n\n  // Handle wave type selector adjustments\n  useEffect(() => {\n    if (isPlaying && oscLeftRef.current && oscRightRef.current) {\n      oscLeftRef.current.type = waveType;\n      oscRightRef.current.type = waveType;\n    }\n  }, [waveType, isPlaying]);\n\n  // Cleanup on unmount\n  useEffect(() => {\n    return () => {\n      stopSoundEngine();\n    };\n  }, []);\n\n  // --- MODULAR TIMELINE TIMER ENGINE (30s) ---\n  useEffect(() => {\n    if (!isPlaying || !isModulationEnabled) {\n      return;\n    }\n\n    const interval = setInterval(() => {\n      setSecondsRemaining((prev) => {\n        if (prev <= 1) {\n          // Time\'s up! Rotate to next phase step seamlessly.\n          setCurrentModStep((step) => {\n            const nextStep = (step + 1) % modulationSteps.length;\n            return nextStep;\n          });\n          return 30; // Reset countdown\n        }\n        return prev - 1;\n      });\n    }, 1000);\n\n    return () => clearInterval(interval);\n  }, [isPlaying, isModulationEnabled, modulationSteps.length]);\n\n  // If modulation changes, trigger a quick refresh on frequencies\n  useEffect(() => {\n    if (isPlaying) {\n      updateFrequencies(carrierFreq, binauralBeatFreq);\n    }\n  }, [currentModStep, isPlaying, updateFrequencies, carrierFreq, binauralBeatFreq]);\n\n  // --- RECHART DRAWING REALTIME VISUALIZER (Stereo ribbon & entrainment breathe mandala) ---\n  useEffect(() => {\n    let animationFrameId: number;\n\n    const renderVisuals = () => {\n      const canvas = canvasRef.current;\n      if (!canvas) return;\n      const ctx = canvas.getContext(\'2d\');\n      if (!ctx) return;\n\n      const width = canvas.width;\n      const height = canvas.height;\n\n      const analyserL = analyserLeftRef.current;\n      const analyserR = analyserRightRef.current;\n\n      const bufferLengthL = analyserL ? analyserL.frequencyBinCount : 256;\n      const bufferLengthR = analyserR ? analyserR.frequencyBinCount : 256;\n\n      const dataArrayL = new Uint8Array(bufferLengthL);\n      const dataArrayR = new Uint8Array(bufferLengthR);\n\n      // Fetch array data on active playing\n      if (isPlaying && analyserL && analyserR) {\n        analyserL.getByteTimeDomainData(dataArrayL);\n        analyserR.getByteTimeDomainData(dataArrayR);\n      } else {\n        // Populate static placeholder baseline waves when muted\n        for (let i = 0; i < bufferLengthL; i++) {\n          dataArrayL[i] = 128 + Math.sin(i * 0.08) * 15;\n          dataArrayR[i] = 128 + Math.sin(i * 0.08 + Math.PI / 3) * 15;\n        }\n      }\n\n      // Solid deep cosmic void background with slight dark grid lines\n      ctx.fillStyle = \'rgba(15, 23, 42, 0.2)\'; // trailing effect\n      ctx.fillRect(0, 0, width, height);\n\n      // Draw audio visual grid\n      ctx.strokeStyle = \'rgba(30, 41, 59, 0.4)\';\n      ctx.lineWidth = 1;\n      for (let i = 50; i < width; i += 100) {\n        ctx.beginPath();\n        ctx.moveTo(i, 0);\n        ctx.lineTo(i, height);\n        ctx.stroke();\n      }\n      for (let j = 40; j < height; j += 80) {\n        ctx.beginPath();\n        ctx.moveTo(0, j);\n        ctx.lineTo(width, j);\n        ctx.stroke();\n      }\n\n      // DRAW SACRED ENTRAINMENT PULSATING MANDALA IN THE CENTER\n      // The respiration speed map smoothly to current binaural beat frequency\n      const timeSec = Date.now() / 1000;\n      const pulsationRatio = 0.5 + 0.5 * Math.sin(timeSec * binauralBeatFreq * Math.PI * 0.4); \n      const breatheRadius = 38 + pulsationRatio * 18; // Oscillates radially\n\n      const centerX = width / 2;\n      const centerY = height / 2;\n\n      // Glowing cosmic background aura\n      const glowGradient = ctx.createRadialGradient(centerX, centerY, 5, centerX, centerY, breatheRadius * 2);\n      glowGradient.addColorStop(0, \'rgba(124, 58, 237, 0.15)\'); // Violent aura\n      glowGradient.addColorStop(1, \'rgba(0, 0, 0, 0)\');\n      ctx.fillStyle = glowGradient;\n      ctx.beginPath();\n      ctx.arc(centerX, centerY, breatheRadius * 2, 0, Math.PI * 2);\n      ctx.fill();\n\n      // Sacred Geometry: Hexagram pattern\n      ctx.strokeStyle = `rgba(168, 85, 247, ${isPlaying ? \'0.45\' : \'0.25\'})`;\n      ctx.lineWidth = 2;\n      ctx.shadowBlur = isPlaying ? 15 : 4;\n      ctx.shadowColor = \'#06b6d4\';\n\n      ctx.beginPath();\n      for (let k = 0; k < 6; k++) {\n        const angle = (k * Math.PI) / 3 + timeSec * 0.12; // slow rot\n        const px = centerX + Math.cos(angle) * breatheRadius;\n        const py = centerY + Math.sin(angle) * breatheRadius;\n        if (k === 0) ctx.moveTo(px, py);\n        else ctx.lineTo(px, py);\n      }\n      ctx.closePath();\n      ctx.stroke();\n\n      // Secondary inverted interlaced triangle\n      ctx.strokeStyle = \'rgba(6, 182, 212, 0.4)\';\n      ctx.beginPath();\n      for (let k = 0; k < 6; k++) {\n        const angle = (k * Math.PI) / 3 + Math.PI / 6 - timeSec * 0.12;\n        const px = centerX + Math.cos(angle) * (breatheRadius * 0.7);\n        const py = centerY + Math.sin(angle) * (breatheRadius * 0.7);\n        if (k === 0) ctx.moveTo(px, py);\n        else ctx.lineTo(px, py);\n      }\n      ctx.closePath();\n      ctx.stroke();\n\n      // Reset simple shadows\n      ctx.shadowBlur = 0;\n\n      // DRAW LEFT CHANNEL WAVE (Emerald/Teal Green ribbon at the top/full)\n      ctx.lineWidth = 2.5;\n      ctx.strokeStyle = \'rgba(16, 185, 129, 0.85)\'; // Green Emerald Left\n      ctx.beginPath();\n      \n      let sliceWidthL = width / bufferLengthL;\n      let xL = 0;\n\n      for (let i = 0; i < bufferLengthL; i++) {\n        const v = dataArrayL[i] / 128.0; // normalised around 1.0\n        // Map wave domain slightly high on the center\n        const y = (v * height) / 2 + (Math.sin(i * 0.05 + timeSec * 2) * (isPlaying ? 8 : 2)); \n\n        if (i === 0) {\n          ctx.moveTo(xL, y);\n        } else {\n          ctx.lineTo(xL, y);\n        }\n        xL += sliceWidthL;\n      }\n      ctx.stroke();\n\n      // DRAW RIGHT CHANNEL WAVE (Indigo/Violet ribbon overlaying)\n      ctx.lineWidth = 2.5;\n      ctx.strokeStyle = \'rgba(99, 102, 241, 0.85)\'; // Indigo Right\n      ctx.beginPath();\n\n      let sliceWidthR = width / bufferLengthR;\n      let xR = 0;\n\n      for (let i = 0; i < bufferLengthR; i++) {\n        const v = dataArrayR[i] / 128.0;\n        // Slightly different wave shift to demonstrate offset visually\n        const y = (v * height) / 2 + (Math.sin(i * 0.05 - timeSec * 2) * (isPlaying ? -8 : -2)); \n\n        if (i === 0) {\n          ctx.moveTo(xR, y);\n        } else {\n          ctx.lineTo(xR, y);\n        }\n        xR += sliceWidthR;\n      }\n      ctx.stroke();\n\n      // Small HUD overlay texts demonstrating live frequency offsets\n      ctx.fillStyle = \'rgba(255, 255, 255, 0.65)\';\n      ctx.font = \'10px monospace\';\n      // Frequency indicator L and R in real-time\n      const activeMod = isModulationEnabled ? modulationSteps[currentModStep] : null;\n      const carrierOffset = activeMod ? activeMod.carrierOffset : 0;\n      const beatOffset = activeMod ? activeMod.beatOffset : 0;\n\n      const currentBase = carrierFreq + carrierOffset;\n      const currentPulse = binauralBeatFreq + beatOffset;\n\n      const freqL = (currentBase - currentPulse / 2).toFixed(1);\n      const freqR = (currentBase + currentPulse / 2).toFixed(1);\n\n      ctx.fillText(`CANAL IZQ: ${freqL} Hz`, 15, 25);\n      ctx.fillText(`CANAL DER: ${freqR} Hz`, width - 150, 25);\n      ctx.fillText(`DIFERENCIA: ${currentPulse.toFixed(1)} Hz (ARR\303\201STRE CORTICAL)`, centerX - 110, height - 15);\n\n      animationFrameId = requestAnimationFrame(renderVisuals);\n    };\n\n    animationFrameId = requestAnimationFrame(renderVisuals);\n    return () => {\n      cancelAnimationFrame(animationFrameId);\n    };\n  }, [isPlaying, binauralBeatFreq, carrierFreq, currentModStep, isModulationEnabled, modulationSteps]);\n\n  // --- GEMINI SERVICE REQUESTS ---"
