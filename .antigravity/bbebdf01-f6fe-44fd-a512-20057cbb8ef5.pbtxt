  file_change {
    absolute_path_uri: "file:///components/BinauralBeatsApp.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "\'use client\';\n\nimport React, { useState, useEffect, useRef, useCallback } from \'react\';\nimport { \n  Play, \n  Pause, \n  Sparkles, \n  RefreshCw, \n  Volume2, \n  Info, \n  Brain, \n  Sliders, \n  Compass, \n  Shuffle, \n  Moon, \n  BookOpen, \n  Heart, \n  Activity, \n  Zap, \n  Check, \n  AlertCircle \n} from \'lucide-react\';\nimport { motion, AnimatePresence } from \'motion/react\';\n\n// Interfaces for structured psychoacoustic programs\ninterface ModulationStep {\n  stepName: string;\n  carrierOffset: number;\n  beatOffset: number;\n}\n\ninterface CustomAIPres {\n  sessionName: string;\n  explanation: string;\n  baseCarrierFrequency: number;\n  binauralBeatFrequency: number;\n  autoModulationPattern: ModulationStep[];\n  suggestedAmbient: string;\n}\n\n// Preset definition\ninterface WavePreset {\n  id: string;\n  name: string;\n  range: string;\n  beatFreq: number;\n  carrierFreq: number;\n  description: string;\n  icon: React.ReactNode;\n}\n\nexport default function BinauralBeatsApp() {\n  // --- SOUND SYNTHESIS REFERENCES ---\n  const audioCtxRef = useRef<AudioContext | null>(null);\n  \n  // Left and Right core oscillators & gain nodes for the binaural offset\n  const oscLeftRef = useRef<OscillatorNode | null>(null);\n  const oscRightRef = useRef<OscillatorNode | null>(null);\n  const oscLeftGainRef = useRef<GainNode | null>(null);\n  const oscRightGainRef = useRef<GainNode | null>(null);\n  \n  // Audio Analysers for left and right outputs (Stereo visualisation)\n  const analyserLeftRef = useRef<AnalyserNode | null>(null);\n  const analyserRightRef = useRef<AnalyserNode | null>(null);\n  \n  // Master control nodes\n  const masterGainRef = useRef<GainNode | null>(null);\n  \n  // Ambient noise generator nodes\n  const ambientSourceRef = useRef<AudioBufferSourceNode | null>(null);\n  const ambientGainRef = useRef<GainNode | null>(null);\n  const ambientFilterRef = useRef<BiquadFilterNode | null>(null);\n  const ambientLFORef = useRef<OscillatorNode | null>(null);\n  const ambientLFOGainRef = useRef<GainNode | null>(null);\n\n  // --- REACT STATES ---\n  const [isPlaying, setIsPlaying] = useState<boolean>(false);\n  const [carrierFreq, setCarrierFreq] = useState<number>(180); // Hz\n  const [binauralBeatFreq, setBinauralBeatFreq] = useState<number>(10); // Hz (Alpha)\n  const [masterVolume, setMasterVolume] = useState<number>(0.5); // 0 - 1\n  const [ambientVolume, setAmbientVolume] = useState<number>(0.3); // 0 - 1\n  const [ambientType, setAmbientType] = useState<string>(\'cosmic\'); // \'none\' | \'pink\' | \'brown\' | \'cosmic\'\n  const [waveType, setWaveType] = useState<\'sine\' | \'triangle\'>(\'sine\');\n  \n  // Modulator parameters\n  const [isModulationEnabled, setIsModulationEnabled] = useState<boolean>(true);\n  const [currentModStep, setCurrentModStep] = useState<number>(0);\n  const [secondsRemaining, setSecondsRemaining] = useState<number>(30);\n  \n  // AI program states\n  const [aiPrompt, setAiPrompt] = useState<string>(\'\');\n  const [isAiLoading, setIsAiLoading] = useState<boolean>(false);\n  const [aiError, setAiError] = useState<string | null>(null);\n  const [activeProgramName, setActiveProgramName] = useState<string>(\'Ondas de Calma Inicial\');\n  const [aiExplanation, setAiExplanation] = useState<string>(\'Esta sesi\303\263n inicial combina ondas portadoras bajas de 180Hz con un pulso de 10Hz en el rango Alfa para sincronizar tus hemisferios y disolver el estr\303\251s.\');\n  \n  // Adaptive modulation pattern\n  const [modulationSteps, setModulationSteps] = useState<ModulationStep[]>([\n    { stepName: \'Sincronizaci\303\263n Inicial\', carrierOffset: 0, beatOffset: 0 },\n    { stepName: \'Activaci\303\263n Cortical\', carrierOffset: 8, beatOffset: 0.5 },\n    { stepName: \'Desplazamiento de Fase\', carrierOffset: -6, beatOffset: -0.5 },\n    { stepName: \'Estabilizaci\303\263n Hemisf\303\251rica\', carrierOffset: 12, beatOffset: 1.0 },\n    { stepName: \'Inversi\303\263n Psicoac\303\272stica\', carrierOffset: -10, beatOffset: -1.0 },\n    { stepName: \'Armonizaci\303\263n Integrada\', carrierOffset: 4, beatOffset: 0 }\n  ]);\n\n  // Canvas visualizer reference\n  const canvasRef = useRef<HTMLCanvasElement | null>(null);\n  const animationFrameIdRef = useRef<number | null>(null);\n\n  // Default wave ranges\n  const presets: WavePreset[] = [\n    { \n      id: \'delta\', \n      name: \'Ondas Delta\', \n      range: \'1 - 4 Hz\', \n      beatFreq: 2.5, \n      carrierFreq: 120, \n      description: \'Sue\303\261o profundo, reparaci\303\263n celular, descanso trascendental libre de sue\303\261os.\',\n      icon: <Moon className=\"w-4 h-4\" /> \n    },\n    { \n      id: \'theta\', \n      name: \'Ondas Theta\', \n      range: \'4 - 8 Hz\', \n      beatFreq: 6.0, \n      carrierFreq: 150, \n      description: \'Meditaci\303\263n budista profunda, estados creativos fluidos, acceso al subconsciente.\',\n      icon: <Sparkles className=\"w-4 h-4\" /> \n    },\n    { \n      id: \'alpha\', \n      name: \'Ondas Alfa\', \n      range: \'8 - 12 Hz\', \n      beatFreq: 10.0, \n      carrierFreq: 180, \n      description: \'Relajaci\303\263n consciente, estado de flujo cognitivo, absorci\303\263n de nuevo aprendizaje.\',\n      icon: <Compass className=\"w-4 h-4\" /> \n    },\n    { \n      id: \'beta\', \n      name: \'Ondas Beta\', \n      range: \'12 - 30 Hz\', \n      beatFreq: 18.0, \n      carrierFreq: 220, \n      description: \'Enfoque ejecutivo acelerado, razonamiento anal\303\255tico, resoluci\303\263n de problemas complejos.\',\n      icon: <Zap className=\"w-4 h-4\" /> \n    },\n    { \n      id: \'gamma\', \n      name: \'Ondas Gamma\', \n      range: \'30 - 45 Hz\', \n      beatFreq: 38.0, \n      carrierFreq: 260, \n      description: \'Comprensi\303\263n integral fulminante, m\303\241xima concentraci\303\263n, memoria de corto plazo integrada.\',\n      icon: <Brain className=\"w-4 h-4 text-emerald-400\" /> \n    },\n  ];\n\n  // Map beat frequency to active band\n  const getActivePresetName = useCallback((freq: number) => {\n    if (freq < 4) return \'Delta (Sue\303\261o Profundo)\';\n    if (freq < 8) return \'Theta (Meditaci\303\263n)\';\n    if (freq < 12) return \'Alfa (Calma Alerta)\';\n    if (freq < 30) return \'Beta (Cognici\303\263n)\';\n    return \'Gamma (Procesamiento Elevado)\';\n  }, []);\n\n  // --- AUDIO SYNTHESIS ENGINE FUNCTIONS ---\n\n  // Generate Noise buffer (Brownian/Pink noise)\n  const generateNoiseBuffer = (type: \'pink\' | \'brown\', audioCtx: AudioContext): AudioBuffer => {\n    const bufferSize = 4 * audioCtx.sampleRate; // 4 seconds loop\n    const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);\n    const data = buffer.getChannelData(0);\n\n    if (type === \'brown\') {\n      let lastOut = 0.0;\n      for (let i = 0; i < bufferSize; i++) {\n        const white = Math.random() * 2 - 1;\n        // Brownian noise integrator formula\n        data[i] = (lastOut + (0.025 * white)) / 1.025;\n        lastOut = data[i];\n        data[i] *= 4.5; // Compensate amplitude loss\n      }\n    } else {\n      // Pink noise algorithm (Voss-McCartney approximation)\n      let b0 = 0, b1 = 0, b2 = 0, b3 = 0, b4 = 0, b5 = 0, b6 = 0;\n      for (let i = 0; i < bufferSize; i++) {\n        const white = Math.random() * 2 - 1;\n        b0 = 0.99886 * b0 + white * 0.0555179;\n        b1 = 0.99332 * b1 + white * 0.0750759;\n        b2 = 0.96900 * b2 + white * 0.1538520;\n        b3 = 0.86650 * b3 + white * 0.3104856;\n        b4 = 0.55000 * b4 + white * 0.5329522;\n        b5 = -0.7616 * b5 - white * 0.0168980;\n        data[i] = b0 + b1 + b2 + b3 + b4 + b5 + b6 + white * 0.5362;\n        b6 = white * 0.115926;\n        data[i] *= 0.11; // Normalize\n      }\n    }\n    return buffer;\n  };\n\n  // Re-start ambient background audionodes\n  const configureAmbientNode = useCallback(() => {\n    const audioCtx = audioCtxRef.current;\n    if (!audioCtx || !isPlaying) return;\n\n    // Stop existing source if playing\n    if (ambientSourceRef.current) {\n      try { ambientSourceRef.current.stop(); } catch (e) {}\n      ambientSourceRef.current.disconnect();\n      ambientSourceRef.current = null;\n    }\n    if (ambientLFORef.current) {\n      try { ambientLFORef.current.stop(); } catch (e) {}\n      ambientLFORef.current.disconnect();\n      ambientLFORef.current = null;\n    }\n\n    if (ambientType === \'none\') {\n      if (ambientGainRef.current) {\n        ambientGainRef.current.gain.setTargetAtTime(0, audioCtx.currentTime, 0.5);\n      }\n      return;\n    }\n\n    // Set ambient gain value smoothly\n    if (ambientGainRef.current) {\n      ambientGainRef.current.gain.setTargetAtTime(ambientVolume * 0.4, audioCtx.currentTime, 0.5);\n    }\n\n    // Generate buffer\n    const bufferType = ambientType === \'cosmic\' ? \'brown\' : (ambientType as \'pink\' | \'brown\');\n    const buffer = generateNoiseBuffer(bufferType, audioCtx);\n    const source = audioCtx.createBufferSource();\n    source.buffer = buffer;\n    source.loop = true;\n\n    // Connect source to filter\n    if (ambientFilterRef.current) {\n      source.connect(ambientFilterRef.current);\n    }\n\n    // High performance slow filtering sweep for Cosmic wind effect\n    if (ambientType === \'cosmic\' && ambientFilterRef.current && ambientLFOGainRef.current) {\n      ambientFilterRef.current.type = \'lowpass\';\n      ambientFilterRef.current.frequency.setValueAtTime(450, audioCtx.currentTime);\n      ambientFilterRef.current.Q.setValueAtTime(3.5, audioCtx.currentTime);\n\n      const lfo = audioCtx.createOscillator();\n      const lfoGain = ambientLFOGainRef.current;\n\n      lfo.type = \'sine\';\n      lfo.frequency.setValueAtTime(0.06, audioCtx.currentTime); // very slow 0.06Hz sweep\n      lfoGain.gain.setValueAtTime(250, audioCtx.currentTime); // span +/- 250Hz around cutoff\n\n      lfo.connect(lfoGain);\n      lfoGain.connect(ambientFilterRef.current.frequency);\n      lfo.start();\n      \n      ambientLFORef.current = lfo;\n    } else if (ambientFilterRef.current) {\n      // Direct pass filter with fixed comfortable static\n      ambientFilterRef.current.type = \'lowpass\';\n      ambientFilterRef.current.frequency.setValueAtTime(1200, audioCtx.currentTime);\n      ambientFilterRef.current.Q.setValueAtTime(0.5, audioCtx.currentTime);\n    }\n\n    source.start();\n    ambientSourceRef.current = source;\n  }, [isPlaying, ambientType, ambientVolume]);\n\n  // Handle manual frequency slides\n  const updateFrequencies = useCallback((base: number, beat: number) => {\n    const audioCtx = audioCtxRef.current;\n    if (!audioCtx || !isPlaying) return;\n\n    // Binaural calculations\n    // Left ear plays: Base - (Beat / 2)\n    // Right ear plays: Base + (Beat / 2)\n    const activeMod = isModulationEnabled ? modulationSteps[currentModStep] : null;\n    const carrierOffset = activeMod ? activeMod.carrierOffset : 0;\n    const beatOffset = activeMod ? activeMod.beatOffset : 0;\n\n    const actualBase = Math.max(80, base + carrierOffset);\n    const actualBeat = Math.max(0.5, beat + beatOffset);\n\n    const freqLeft = actualBase - (actualBeat / 2);\n    const freqRight = actualBase + (actualBeat / 2);\n\n    const now = audioCtx.currentTime;\n    if (oscLeftRef.current && oscRightRef.current) {\n      // Smooth portamento preventing click & brain shocks\n      oscLeftRef.current.frequency.setTargetAtTime(freqLeft, now, 1.2);\n      oscRightRef.current.frequency.setTargetAtTime(freqRight, now, 1.2);\n    }\n  }, [isPlaying, isModulationEnabled, modulationSteps, currentModStep]);\n\n  // Main system sound trigger\n  const runSoundEngine = async () => {\n    // Initialize Web Audio context\n    if (!audioCtxRef.current) {\n      const AudioCtxClass = window.AudioContext || (window as any).webkitAudioContext;\n      audioCtxRef.current = new AudioCtxClass();\n    }\n\n    const audioCtx = audioCtxRef.current;\n\n    // Resume context if browser blocked it\n    if (audioCtx.state === \'suspended\') {\n      await audioCtx.resume();\n    }\n\n    if (isPlaying) {\n      // Disconnect and silence nodes\n      stopSoundEngine();\n      setIsPlaying(false);\n      return;\n    }\n\n    // BUILD MASTER PIPELINE\n    const masterGain = audioCtx.createGain();\n    masterGain.gain.setValueAtTime(masterVolume, audioCtx.currentTime);\n    masterGain.connect(audioCtx.destination);\n    masterGainRef.current = masterGain;\n\n    // BUILD AMBIENT STATIC SYSTEM\n    const ambientGain = audioCtx.createGain();\n    ambientGain.gain.setValueAtTime(ambientVolume * 0.4, audioCtx.currentTime);\n    ambientGain.connect(masterGain);\n    ambientGainRef.current = ambientGain;\n\n    const ambientFilter = audioCtx.createBiquadFilter();\n    ambientFilter.connect(ambientGain);\n    ambientFilterRef.current = ambientFilter;\n\n    const ambientLFOGain = audioCtx.createGain();\n    ambientLFOGain.connect(ambientFilter.frequency);\n    ambientLFOGainRef.current = ambientLFOGain;\n\n    // BUILD BINAURAL CHANNELS\n    // Config stereo splitter (Separate left and right channels)\n    const analyserLeft = audioCtx.createAnalyser();\n    analyserLeft.fftSize = 512;\n    analyserLeftRef.current = analyserLeft;\n\n    const analyserRight = audioCtx.createAnalyser();\n    analyserRight.fftSize = 512;\n    analyserRightRef.current = analyserRight;\n\n    // Stereo Panner Nodes\n    const pannerLeft = audioCtx.createStereoPanner();\n    pannerLeft.pan.setValueAtTime(-1.0, audioCtx.currentTime); // Complete left ear\n\n    const pannerRight = audioCtx.createStereoPanner();\n    pannerRight.pan.setValueAtTime(1.0, audioCtx.currentTime); // Complete right ear\n\n    // Gains per channel\n    const oscLeftGain = audioCtx.createGain();\n    oscLeftGain.gain.setValueAtTime(0.5, audioCtx.currentTime);\n    oscLeftGainRef.current = oscLeftGain;\n\n    const oscRightGain = audioCtx.createGain();\n    oscRightGain.gain.setValueAtTime(0.5, audioCtx.currentTime);\n    oscRightGainRef.current = oscRightGain;\n\n    // Connect Left System: Oscillator -> Analyser -> Pan Left -> Master\n    oscLeftGain.connect(analyserLeft);\n    analyserLeft.connect(pannerLeft);\n    pannerLeft.connect(masterGain);\n\n    // Connect Right System: Oscillator -> Analyser -> Pan Right -> Master\n    oscRightGain.connect(analyserRight);\n    analyserRight.connect(pannerRight);\n    pannerRight.connect(masterGain);\n\n    // Create Left and Right Sine/Triangle Oscillators\n    const oscLeft = audioCtx.createOscillator();\n    const oscRight = audioCtx.createOscillator();\n\n    oscLeft.type = waveType;\n    oscRight.type = waveType;\n\n    oscLeftRef.current = oscLeft;\n    oscRightRef.current = oscRight;\n\n    oscLeft.connect(oscLeftGain);\n    oscRight.connect(oscRightGain);\n\n    // Trigger oscillations\n    oscLeft.start();\n    oscRight.start();\n\n    setIsPlaying(true);\n  };\n\n  // Safe sound shutdown\n  const stopSoundEngine = () => {\n    // Left osc cleanup\n    if (oscLeftRef.current) {\n      try { oscLeftRef.current.stop(); } catch (e) {}\n      oscLeftRef.current.disconnect();\n      oscLeftRef.current = null;\n    }\n    // Right osc cleanup\n    if (oscRightRef.current) {\n      try { oscRightRef.current.stop(); } catch (e) {}\n      oscRightRef.current.disconnect();\n      oscRightRef.current = null;\n    }\n    // Ambient source cleanup\n    if (ambientSourceRef.current) {\n      try { ambientSourceRef.current.stop(); } catch (e) {}\n      ambientSourceRef.current.disconnect();\n      ambientSourceRef.current = null;\n    }\n    // LFO cleanup\n    if (ambientLFORef.current) {\n      try { ambientLFORef.current.stop(); } catch (e) {}\n      ambientLFORef.current.disconnect();\n      ambientLFORef.current = null;\n    }\n    // Disconnect pipelines\n    if (masterGainRef.current) {\n      masterGainRef.current.disconnect();\n      masterGainRef.current = null;\n    }\n    setIsPlaying(false);\n  };\n\n  // --- REACT ACTIONS ON PLAY & PARAM CHANGE ---\n\n  // Handle active playback frequency updating\n  useEffect(() => {\n    if (isPlaying) {\n      updateFrequencies(carrierFreq, binauralBeatFreq);\n    }\n  }, [isPlaying, carrierFreq, binauralBeatFreq, updateFrequencies, currentModStep, isModulationEnabled]);\n\n  // Restart ambient noise when ambient preferences change\n  useEffect(() => {\n    configureAmbientNode();\n  }, [isPlaying, ambientType, configureAmbientNode]);\n\n  // Adjust volume levels dynamically\n  useEffect(() => {\n    const audioCtx = audioCtxRef.current;\n    if (audioCtx && isPlaying) {\n      if (masterGainRef.current) {\n        masterGainRef.current.gain.setTargetAtTime(masterVolume, audioCtx.currentTime, 0.1);\n      }\n      if (ambientGainRef.current) {\n        ambientGainRef.current.gain.setTargetAtTime(ambientVolume * 0.4, audioCtx.currentTime, 0.1);\n      }\n    }\n  }, [masterVolume, ambientVolume, isPlaying]);\n\n  // Handle wave type selector adjustments\n  useEffect(() => {\n    if (isPlaying && oscLeftRef.current && oscRightRef.current) {\n      oscLeftRef.current.type = waveType;\n      oscRightRef.current.type = waveType;\n    }\n  }, [waveType, isPlaying]);\n\n  // Cleanup on unmount\n  useEffect(() => {\n    return () => {\n      stopSoundEngine();\n      if (animationFrameIdRef.current) {\n        cancelAnimationFrame(animationFrameIdRef.current);\n      }\n    };\n  }, []);\n\n  // --- MODULAR TIMELINE TIMER ENGINE (30s) ---\n  useEffect(() => {\n    if (!isPlaying || !isModulationEnabled) {\n      setSecondsRemaining(30);\n      return;\n    }\n\n    const interval = setInterval(() => {\n      setSecondsRemaining((prev) => {\n        if (prev <= 1) {\n          // Time\'s up! Rotate to next phase step seamlessly.\n          setCurrentModStep((step) => {\n            const nextStep = (step + 1) % modulationSteps.length;\n            return nextStep;\n          });\n          return 30; // Reset countdown\n        }\n        return prev - 1;\n      });\n    }, 1000);\n\n    return () => clearInterval(interval);\n  }, [isPlaying, isModulationEnabled, modulationSteps.length]);\n\n  // If modulation changes, trigger a quick refresh on frequencies\n  useEffect(() => {\n    if (isPlaying) {\n      updateFrequencies(carrierFreq, binauralBeatFreq);\n    }\n  }, [currentModStep, isPlaying, updateFrequencies, carrierFreq, binauralBeatFreq]);\n\n  // --- RECHART DRAWING REALTIME VISUALIZER (Stereo ribbon & entrainment breathe mandala) ---\n  const renderVisuals = useCallback(() => {\n    const canvas = canvasRef.current;\n    if (!canvas) return;\n    const ctx = canvas.getContext(\'2d\');\n    if (!ctx) return;\n\n    const width = canvas.width;\n    const height = canvas.height;\n\n    const analyserL = analyserLeftRef.current;\n    const analyserR = analyserRightRef.current;\n\n    const bufferLengthL = analyserL ? analyserL.frequencyBinCount : 256;\n    const bufferLengthR = analyserR ? analyserR.frequencyBinCount : 256;\n\n    const dataArrayL = new Uint8Array(bufferLengthL);\n    const dataArrayR = new Uint8Array(bufferLengthR);\n\n    // Fetch array data on active playing\n    if (isPlaying && analyserL && analyserR) {\n      analyserL.getByteTimeDomainData(dataArrayL);\n      analyserR.getByteTimeDomainData(dataArrayR);\n    } else {\n      // Populate static placeholder baseline waves when muted\n      for (let i = 0; i < bufferLengthL; i++) {\n        dataArrayL[i] = 128 + Math.sin(i * 0.08) * 15;\n        dataArrayR[i] = 128 + Math.sin(i * 0.08 + Math.PI / 3) * 15;\n      }\n    }\n\n    // Solid deep cosmic void background with slight dark grid lines\n    ctx.fillStyle = \'rgba(15, 23, 42, 0.2)\'; // trailing effect\n    ctx.fillRect(0, 0, width, height);\n\n    // Draw audio visual grid\n    ctx.strokeStyle = \'rgba(30, 41, 59, 0.4)\';\n    ctx.lineWidth = 1;\n    for (let i = 50; i < width; i += 100) {\n      ctx.beginPath();\n      ctx.moveTo(i, 0);\n      ctx.lineTo(i, height);\n      ctx.stroke();\n    }\n    for (let j = 40; j < height; j += 80) {\n      ctx.beginPath();\n      ctx.moveTo(0, j);\n      ctx.lineTo(width, j);\n      ctx.stroke();\n    }\n\n    // DRAW SACRED ENTRAINMENT PULSATING MANDALA IN THE CENTER\n    // The respiration speed map smoothly to current binaural beat frequency\n    const timeSec = Date.now() / 1000;\n    const pulsationRatio = 0.5 + 0.5 * Math.sin(timeSec * binauralBeatFreq * Math.PI * 0.4); \n    const breatheRadius = 38 + pulsationRatio * 18; // Oscillates radially\n\n    const centerX = width / 2;\n    const centerY = height / 2;\n\n    // Glowing cosmic background aura\n    const glowGradient = ctx.createRadialGradient(centerX, centerY, 5, centerX, centerY, breatheRadius * 2);\n    glowGradient.addColorStop(0, \'rgba(124, 58, 237, 0.15)\'); // Violent aura\n    glowGradient.addColorStop(1, \'rgba(0, 0, 0, 0)\');\n    ctx.fillStyle = glowGradient;\n    ctx.beginPath();\n    ctx.arc(centerX, centerY, breatheRadius * 2, 0, Math.PI * 2);\n    ctx.fill();\n\n    // Sacred Geometry: Hexagram pattern\n    ctx.strokeStyle = `rgba(168, 85, 247, ${isPlaying ? \'0.45\' : \'0.25\'})`;\n    ctx.lineWidth = 2;\n    ctx.shadowBlur = isPlaying ? 15 : 4;\n    ctx.shadowColor = \'#06b6d4\';\n\n    ctx.beginPath();\n    for (let k = 0; k < 6; k++) {\n      const angle = (k * Math.PI) / 3 + timeSec * 0.12; // slow rot\n      const px = centerX + Math.cos(angle) * breatheRadius;\n      const py = centerY + Math.sin(angle) * breatheRadius;\n      if (k === 0) ctx.moveTo(px, py);\n      else ctx.lineTo(px, py);\n    }\n    ctx.closePath();\n    ctx.stroke();\n\n    // Secondary inverted interlaced triangle\n    ctx.strokeStyle = \'rgba(6, 182, 212, 0.4)\';\n    ctx.beginPath();\n    for (let k = 0; k < 6; k++) {\n      const angle = (k * Math.PI) / 3 + Math.PI / 6 - timeSec * 0.12;\n      const px = centerX + Math.cos(angle) * (breatheRadius * 0.7);\n      const py = centerY + Math.sin(angle) * (breatheRadius * 0.7);\n      if (k === 0) ctx.moveTo(px, py);\n      else ctx.lineTo(px, py);\n    }\n    ctx.closePath();\n    ctx.stroke();\n\n    // Reset simple shadows\n    ctx.shadowBlur = 0;\n\n    // DRAW LEFT CHANNEL WAVE (Emerald/Teal Green ribbon at the top/full)\n    ctx.lineWidth = 2.5;\n    ctx.strokeStyle = \'rgba(16, 185, 129, 0.85)\'; // Green Emerald Left\n    ctx.beginPath();\n    \n    let sliceWidthL = width / bufferLengthL;\n    let xL = 0;\n\n    for (let i = 0; i < bufferLengthL; i++) {\n      const v = dataArrayL[i] / 128.0; // normalised around 1.0\n      // Map wave domain slightly high on the center\n      const y = (v * height) / 2 + (Math.sin(i * 0.05 + timeSec * 2) * (isPlaying ? 8 : 2)); \n\n      if (i === 0) {\n        ctx.moveTo(xL, y);\n      } else {\n        ctx.lineTo(xL, y);\n      }\n      xL += sliceWidthL;\n    }\n    ctx.stroke();\n\n    // DRAW RIGHT CHANNEL WAVE (Indigo/Violet ribbon overlaying)\n    ctx.lineWidth = 2.5;\n    ctx.strokeStyle = \'rgba(99, 102, 241, 0.85)\'; // Indigo Right\n    ctx.beginPath();\n\n    let sliceWidthR = width / bufferLengthR;\n    let xR = 0;\n\n    for (let i = 0; i < bufferLengthR; i++) {\n      const v = dataArrayR[i] / 128.0;\n      // Slightly different wave shift to demonstrate offset visually\n      const y = (v * height) / 2 + (Math.sin(i * 0.05 - timeSec * 2) * (isPlaying ? -8 : -2)); \n\n      if (i === 0) {\n        ctx.moveTo(xR, y);\n      } else {\n        ctx.lineTo(xR, y);\n      }\n      xR += sliceWidthR;\n    }\n    ctx.stroke();\n\n    // Small HUD overlay texts demonstrating live frequency offsets\n    ctx.fillStyle = \'rgba(255, 255, 255, 0.65)\';\n    ctx.font = \'10px monospace\';\n    // Frequency indicator L and R in real-time\n    const activeMod = isModulationEnabled ? modulationSteps[currentModStep] : null;\n    const carrierOffset = activeMod ? activeMod.carrierOffset : 0;\n    const beatOffset = activeMod ? activeMod.beatOffset : 0;\n\n    const currentBase = carrierFreq + carrierOffset;\n    const currentPulse = binauralBeatFreq + beatOffset;\n\n    const freqL = (currentBase - currentPulse / 2).toFixed(1);\n    const freqR = (currentBase + currentPulse / 2).toFixed(1);\n\n    ctx.fillText(`CANAL IZQ: ${freqL} Hz`, 15, 25);\n    ctx.fillText(`CANAL DER: ${freqR} Hz`, width - 150, 25);\n    ctx.fillText(`DIFERENCIA: ${currentPulse.toFixed(1)} Hz (ARR\303\201STRE CORTICAL)`, centerX - 110, height - 15);\n\n    animationFrameIdRef.current = requestAnimationFrame(renderVisuals);\n  }, [isPlaying, binauralBeatFreq, carrierFreq, currentModStep, isModulationEnabled, modulationSteps]);\n\n  // Setup loop for animation\n  useEffect(() => {\n    animationFrameIdRef.current = requestAnimationFrame(renderVisuals);\n    return () => {\n      if (animationFrameIdRef.current) {\n        cancelAnimationFrame(animationFrameIdRef.current);\n      }\n    };\n  }, [renderVisuals]);\n\n  // --- GEMINI SERVICE REQUESTS ---\n  const launchAiArchitect = async () => {\n    if (!aiPrompt.trim()) return;\n    setIsAiLoading(true);\n    setAiError(null);\n\n    try {\n      const response = await fetch(\'/api/psychoacoustic\', {\n        method: \'POST\',\n        headers: { \'Content-Type\': \'application/json\' },\n        body: JSON.stringify({ prompt: aiPrompt })\n      });\n\n      if (!response.ok) {\n        const errVal = await response.json();\n        throw new Error(errVal.error || \'No se pudo generar la prescripci\303\263n ac\303\272stica.\');\n      }\n\n      const program: CustomAIPres = await response.json();\n\n      // Configure frequencies instantly from Gemini JSON suggestion\n      setCarrierFreq(program.baseCarrierFrequency);\n      setBinauralBeatFreq(program.binauralBeatFrequency);\n      setActiveProgramName(program.sessionName);\n      setAiExplanation(program.explanation);\n      setModulationSteps(program.autoModulationPattern);\n      setCurrentModStep(0);\n      setSecondsRemaining(30);\n\n      // Auto assign ambient\n      const ambType = program.suggestedAmbient.toLowerCase();\n      if (ambType.includes(\'marr\303\263n\') || ambType.includes(\'brown\')) {\n        setAmbientType(\'brown\');\n      } else if (ambType.includes(\'rosa\') || ambType.includes(\'pink\')) {\n        setAmbientType(\'pink\');\n      } else if (ambType.includes(\'cosm\') || ambType.includes(\'viento\') || ambType.includes(\'espacio\')) {\n        setAmbientType(\'cosmic\');\n      } else {\n        setAmbientType(\'none\');\n      }\n\n    } catch (err: any) {\n      console.error(err);\n      setAiError(err.message || \'Error resolviendo la programaci\303\263n ac\303\272stica de IA.\');\n    } finally {\n      setIsAiLoading(false);\n    }\n  };\n\n  // Preset quick click loader\n  const loadPreset = (preset: WavePreset) => {\n    setCarrierFreq(preset.carrierFreq);\n    setBinauralBeatFreq(preset.beatFreq);\n    setActiveProgramName(preset.name);\n    setAiExplanation(preset.description);\n    \n    // Set typical modulation intervals suitable for the waveform preset\n    const scale = preset.beatFreq > 15 ? 1.5 : 0.6; \n    setModulationSteps([\n      { stepName: \'Sincronizaci\303\263n Inicial\', carrierOffset: 0, beatOffset: 0 },\n      { stepName: \'Estimulaci\303\263n de Amplitud\', carrierOffset: Math.round(5 * scale), beatOffset: 0.1 * scale },\n      { stepName: \'Fase de Absorci\303\263n\', carrierOffset: Math.round(-4 * scale), beatOffset: -0.2 * scale },\n      { stepName: \'Modulaci\303\263n Sostenida\', carrierOffset: Math.round(8 * scale), beatOffset: 0.3 * scale },\n      { stepName: \'Anti-Habituaci\303\263n Activa\', carrierOffset: Math.round(-6 * scale), beatOffset: -0.1 * scale },\n      { stepName: \'Sinton\303\255a de Cierre\', carrierOffset: Math.round(2 * scale), beatOffset: 0 }\n    ]);\n    \n    setCurrentModStep(0);\n    setSecondsRemaining(30);\n  };\n\n  // Modulator statistics\n  const currentActualCarrier = carrierFreq + (isModulationEnabled ? modulationSteps[currentModStep].carrierOffset : 0);\n  const currentActualBeat = binauralBeatFreq + (isModulationEnabled ? modulationSteps[currentModStep].beatOffset : 0);\n\n  return (\n    <div id=\"psychoacoustic-dashboard\" className=\"min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans selection:bg-purple-900 selection:text-white\">\n      \n      {/* HEADER SECTION */}\n      <header id=\"dashboard-header\" className=\"border-b border-slate-900 bg-slate-950/80 backdrop-blur-md sticky top-0 z-40\">\n        <div className=\"max-w-6xl mx-auto px-4 py-4 flex items-center justify-between\">\n          <div className=\"flex items-center space-x-3\">\n            <div className=\"bg-gradient-to-tr from-purple-600 to-cyan-500 p-2.5 rounded-xl shadow-lg ring-1 ring-white/10\">\n              <Activity className=\"w-5 h-5 text-white animate-pulse\" />\n            </div>\n            <div>\n              <h1 className=\"text-xl font-bold tracking-tight bg-gradient-to-r from-white via-slate-200 to-slate-400 bg-clip-text text-transparent\">\n                Sonidos Binaurales Modulares\n              </h1>\n              <p className=\"text-xs text-slate-500 font-mono tracking-wider\">\n                NEURO-ENTRAINMENT ENGINE ESP \342\200\242 PSICOAC\303\232STICA ACTIVA\n              </p>\n            </div>\n          </div>\n          \n          <div className=\"flex items-center space-x-4\">\n            {isPlaying ? (\n              <span className=\"flex items-center space-x-2 text-xs font-mono px-3 py-1.5 rounded-full bg-emerald-500/10 text-emerald-400 ring-1 ring-emerald-500/20\">\n                <span className=\"w-2 h-2 rounded-full bg-emerald-500 animate-ping\" />\n                <span>ACOPLAMIENTO ACTIVO</span>\n              </span>\n            ) : (\n              <span className=\"text-xs font-mono px-3 py-1.5 rounded-full bg-slate-900 text-slate-400 border border-slate-800\">\n                SINTETIZADOR SILENCIADO\n              </span>\n            )}\n          </div>\n        </div>\n      </header>\n\n      {/* MAIN CONTAINER */}\n      <main id=\"dashboard-main\" className=\"flex-1 max-w-6xl w-full mx-auto p-4 grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch\">\n        \n        {/* LEFT COLUMN: VISUALIZATION & MODULATION TIMELINE (Span 7) */}\n        <section id=\"column-left\" className=\"lg:col-span-7 flex flex-col gap-6\">\n          \n          {/* STEREOPHONIC WAVE VISUALIZER CARD */}\n          <div id=\"card-visualizer\" className=\"bg-slate-900/60 border border-slate-900 rounded-3xl p-5 flex flex-col justify-between overflow-hidden relative group backdrop-blur-md\">\n            <div className=\"flex justify-between items-center mb-3\">\n              <div className=\"flex items-center space-x-2\">\n                <Activity className=\"w-4 h-4 text-cyan-400\" />\n                <h2 className=\"text-sm font-semibold text-slate-200 tracking-wide\">\n                  Visualizador Hemisf\303\251rico Est\303\251reo en Vivo\n                </h2>\n              </div>\n              <div className=\"text-[10px] font-mono text-slate-400 bg-slate-950 px-2.5 py-1 rounded-md border border-slate-800/60\">\n                {waveType === \'sine\' ? \'SENOIDAL PURA\' : \'TRIANGULAR COGNITIVA\'}\n              </div>\n            </div>\n\n            {/* Simulated stereo oscilloscopes inside html5 high fidelity performance canvas */}\n            <div className=\"relative w-full h-56 bg-slate-950 rounded-2xl overflow-hidden border border-slate-800/50\">\n              <canvas \n                ref={canvasRef} \n                width={650} \n                height={224} \n                className=\"w-full h-full block\" \n              />\n              \n              {/* Overlay shadow borders */}\n              <div className=\"absolute inset-x-0 top-0 h-4 bg-gradient-to-b from-slate-950 to-transparent pointer-events-none\" />\n              <div className=\"absolute inset-x-0 bottom-0 h-4 bg-gradient-to-t from-slate-950 to-transparent pointer-events-none\" />\n            </div>\n\n            <div className=\"mt-4 flex items-center justify-between text-xs text-slate-400 font-mono\">\n              <div className=\"flex items-center space-x-2\">\n                <div className=\"w-2.5 h-2.5 rounded-sm bg-emerald-500\" />\n                <span>O\303\255do Izquierdo (-)</span>\n              </div>\n              <div className=\"flex items-center space-x-2\">\n                <div className=\"w-2.5 h-2.5 rounded-sm bg-indigo-500\" />\n                <span>O\303\255do Derecho (+)</span>\n              </div>\n              <div className=\"flex items-center space-x-1 text-slate-500\">\n                <Info className=\"w-3.5 h-3.5\" />\n                <span>Usa auriculares para percibir el efecto.</span>\n              </div>\n            </div>\n          </div>\n\n          {/* 30-SECOND ANTI-ADAPTATION ENGINE TIMELINE */}\n          <div id=\"card-modulation-timeline\" className=\"bg-slate-900/60 border border-slate-900 rounded-3xl p-6 relative backdrop-blur-md\">\n            <div className=\"flex items-center justify-between mb-4\">\n              <div className=\"flex items-center space-x-2\">\n                <RefreshCw className=\"w-4 h-4 text-purple-400 animate-spin\" style={{ animationDuration: \'10s\' }} />\n                <div>\n                  <h3 className=\"text-sm font-semibold text-slate-200\">\n                    Bucle Modular Anti-Adaptaci\303\263n Clic-Prohibido\n                  </h3>\n                  <p className=\"text-xs text-slate-500\">Secuencia din\303\241mica de arrastre cada 30 segundos</p>\n                </div>\n              </div>\n\n              <div className=\"flex items-center space-x-3\">\n                <div className=\"flex items-center\">\n                  <label htmlFor=\"modulation-toggle\" className=\"sr-only\">Activar Auto-Modulaci\303\263n</label>\n                  <button \n                    id=\"modulation-toggle\"\n                    onClick={() => {\n                      setIsModulationEnabled(!isModulationEnabled);\n                      setSecondsRemaining(30);\n                    }}\n                    className={`relative inline-flex h-6 w-11 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 focus:ring-offset-slate-950 ${isModulationEnabled ? \'bg-purple-600\' : \'bg-slate-800\'}`}\n                  >\n                    <span\n                      className={`pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out ${isModulationEnabled ? \'translate-x-5\' : \'translate-x-0\'}`}\n                    />\n                  </button>\n                </div>\n                <span className=\"text-xs font-mono font-medium text-slate-300\">\n                  {isModulationEnabled ? \'ACTIVADO\' : \'CONGELADO\'}\n                </span>\n              </div>\n            </div>\n\n            {/* Time interval dynamic indicator bar */}\n            <div className=\"bg-slate-950 p-4 rounded-2xl border border-slate-800/80 mb-5 relative overflow-hidden flex items-center justify-between\">\n              <div className=\"z-10\">\n                <span className=\"text-[10px] font-mono text-purple-400 tracking-wider\">FASE ACTUAL EN CURSO ({currentModStep + 1}/6)</span>\n                <h4 className=\"text-base font-bold text-slate-100 mt-0.5\">\n                  {modulationSteps[currentModStep]?.stepName || \'Modulaci\303\263n de Fase\'}\n                </h4>\n                <div className=\"flex space-x-4 mt-2 text-xs font-mono text-slate-400\">\n                  <span>Desv. Portadora: <strong className=\"text-cyan-400\">{modulationSteps[currentModStep]?.carrierOffset >= 0 ? `+${modulationSteps[currentModStep]?.carrierOffset}` : modulationSteps[currentModStep]?.carrierOffset} Hz</strong></span>\n                  <span>Desv. Pulso: <strong className=\"text-emerald-400\">{modulationSteps[currentModStep]?.beatOffset >= 0 ? `+${modulationSteps[currentModStep]?.beatOffset}` : modulationSteps[currentModStep]?.beatOffset} Hz</strong></span>\n                </div>\n              </div>\n\n              <div className=\"flex flex-col items-end z-10\">\n                <span className=\"text-[10px] font-mono text-slate-500\">SIGUIENTE CORRECCI\303\223N</span>\n                <span className=\"text-3xl font-extrabold font-mono text-slate-50 tracking-tight\">\n                  0:{secondsRemaining < 10 ? `0${secondsRemaining}` : secondsRemaining}\n                </span>\n              </div>\n\n              {/* Progress linear bar overlay inside background */}\n              {isWithModulationProgress(isModulationEnabled, secondsRemaining) && (\n                <div \n                  className=\"absolute bottom-0 left-0 h-1 bg-gradient-to-r from-purple-600 to-cyan-500 transition-all duration-1000 ease-linear\"\n                  style={{ width: `${((30 - secondsRemaining) / 30) * 100}%` }}\n                />\n              )}\n            </div>\n\n            {/* Modulation Grid List */}\n            <div className=\"grid grid-cols-2 sm:grid-cols-3 gap-3\">\n              {modulationSteps.map((step, index) => {\n                const isActive = index === currentModStep && isModulationEnabled;\n                return (\n                  <div \n                    key={index}\n                    className={`p-3 rounded-xl border text-left transition-all duration-300 ${\n                      isActive \n                        ? \'bg-purple-950/40 border-purple-500/60 ring-1 ring-purple-500/20\' \n                        : \'bg-slate-950/40 border-slate-900/60 text-slate-400\'\n                    }`}\n                  >\n                    <div className=\"flex items-center justify-between mb-1.5\">\n                      <span className=\"text-[9px] font-mono text-slate-500\">ETAPA 0{index + 1}</span>\n                      {isActive && <span className=\"w-1.5 h-1.5 rounded-full bg-purple-400 animate-ping\" />}\n                    </div>\n                    <div className=\"text-xs font-semibold truncate text-slate-200\">\n                      {step.stepName}\n                    </div>\n                    <div className=\"grid grid-cols-2 gap-1 mt-2 text-[10px] font-mono text-slate-400\">\n                      <div>Port: {step.carrierOffset >= 0 ? `+${step.carrierOffset}` : step.carrierOffset}Hz</div>\n                      <div>Beat: {step.beatOffset >= 0 ? `+${step.beatOffset}` : step.beatOffset}Hz</div>\n                    </div>\n                  </div>\n                );\n              })}\n            </div>\n\n            <p className=\"text-[11px] text-slate-500 mt-4 leading-relaxed bg-slate-950/30 p-3 rounded-xl border border-slate-900/40\">\n              \360\237\222\241 <strong>\302\277Por qu\303\251 cambiar cada 30 segundos?</strong> Para contrarrestar la adaptaci\303\263n sensorial del c\303\263rtex auditivo primario. Al deslizar micromodulaciones sutiles, el cerebro se mantiene activamente sincronizado en este intervalo constante, maximizando la efectividad curativa u optimizadora.\n            </p>\n          </div>\n\n        </section>\n\n        {/* RIGHT COLUMN: MANUAL FREQUENCY ENGINE & IA SESSION ARCHITECT (Span 5) */}\n        <section id=\"column-right\" className=\"lg:col-span-5 flex flex-col gap-6\">\n          \n          {/* CONTROL MASTER POWER & GENERAL GAIN */}\n          <div id=\"card-master-power\" className=\"bg-gradient-to-b from-slate-900 to-slate-950 border border-slate-900 rounded-3xl p-6 text-center shadow-xl relative overflow-hidden\">\n            <div className=\"absolute right-0 top-0 translate-x-12 -translate-y-12 w-44 h-44 bg-purple-600/10 rounded-full blur-2xl\" />\n            <div className=\"absolute left-0 bottom-0 -translate-x-12 translate-y-12 w-44 h-44 bg-cyan-500/10 rounded-full blur-2xl\" />\n\n            <div className=\"relative z-10\">\n              <button \n                onClick={runSoundEngine}\n                className={`w-20 h-20 rounded-full flex items-center justify-center mx-auto transition-all duration-500 hover:scale-105 active:scale-95 shadow-2xl ${\n                  isPlaying \n                    ? \'bg-gradient-to-tr from-red-600 to-amber-500 text-white ring-4 ring-red-500/30 shadow-red-500/20\' \n                    : \'bg-gradient-to-tr from-purple-600 to-cyan-500 text-white ring-4 ring-purple-600/30 shadow-purple-500/20\'\n                }`}\n              >\n                {isPlaying ? <Pause className=\"w-8 h-8 fill-white\" /> : <Play className=\"w-8 h-8 fill-white translate-x-0.5\" />}\n              </button>\n\n              <h2 className=\"text-lg font-bold text-slate-100 mt-4 leading-none\">\n                {isPlaying ? \'Silenciar Prescripci\303\263n\' : \'Activar Sonidos Binaurales\'}\n              </h2>\n              <p className=\"text-xs text-slate-400 mt-1.5 font-mono\">\n                {isPlaying \n                  ? `TRANSMITIENDO EN VIVO A Freq real: ${currentActualCarrier.toFixed(1)}Hz` \n                  : \'SINTETIZADOR DIGITAL DE AUDIO LISTO\'}\n              </p>\n\n              {/* Master Volume Slider */}\n              <div className=\"mt-5 max-w-sm mx-auto\">\n                <div className=\"flex justify-between items-center text-xs mb-1 font-mono text-slate-400\">\n                  <div className=\"flex items-center space-x-1.5\">\n                    <Volume2 className=\"w-4 h-4 text-purple-400\" />\n                    <span>Volumen General</span>\n                  </div>\n                  <span>{Math.round(masterVolume * 100)}%</span>\n                </div>\n                <input \n                  type=\"range\" \n                  min=\"0\" \n                  max=\"100\" \n                  value={masterVolume * 100} \n                  onChange={(e) => setMasterVolume(parseInt(e.target.value) / 100)}\n                  className=\"w-full accent-purple-500 bg-slate-850 h-1.5 rounded-lg cursor-pointer\"\n                />\n              </div>\n            </div>\n          </div>\n\n          {/* AI MIND PROGRAM ARCHITECT PANEL (Gemini integration) */}\n          <div id=\"card-ai-designer\" className=\"bg-slate-900/60 border border-slate-900 rounded-3xl p-5 backdrop-blur-md relative overflow-hidden\">\n            <div className=\"absolute right-3 top-3\">\n              <Sparkles className=\"w-5 h-5 text-purple-400/80 animate-pulse\" />\n            </div>\n\n            <div className=\"flex items-center space-x-2 mb-3\">\n              <Brain className=\"w-4 h-4 text-purple-400\" />\n              <h3 className=\"text-sm font-semibold text-slate-200\">\n                Dise\303\261ador de Frecuencias con IA (Gemini 3.5)\n              </h3>\n            </div>\n\n            <div className=\"space-y-4\">\n              <p className=\"text-xs text-slate-400 leading-relaxed\">\n                Describe tu estado actual, nivel de ansiedad o tu meta cognitiva. La IA recalcular\303\241 cient\303\255ficamente las frecuencias base, el desv\303\255o adaptativo y los bucles ideales.\n              </p>\n\n              <div>\n                <textarea \n                  value={aiPrompt}\n                  onChange={(e) => setAiPrompt(e.target.value)}\n                  placeholder=\"Ej: Tengo que estudiar c\303\241lculo complejo por 3h. Siento fatiga mental y estr\303\251s moderado...\"\n                  rows={2}\n                  className=\"w-full text-slate-200 placeholder:text-slate-500 bg-slate-950 border border-slate-850 rounded-2xl p-3 focus:outline-none focus:ring-1 focus:ring-purple-500 text-xs resize-none\"\n                />\n              </div>\n\n              <button \n                onClick={launchAiArchitect}\n                disabled={isAiLoading || !aiPrompt.trim()}\n                className=\"w-full bg-slate-100 hover:bg-white text-slate-950 hover:text-black font-semibold text-xs py-2.5 px-4 rounded-xl transition duration-200 flex items-center justify-center space-x-2 disabled:bg-slate-800 disabled:text-slate-500 disabled:cursor-not-allowed group\"\n              >\n                {isAiLoading ? (\n                  <>\n                    <RefreshCw className=\"w-4 h-4 animate-spin text-slate-950\" />\n                    <span>Calculando Neuro-Prescripci\303\263n...</span>\n                  </>\n                ) : (\n                  <>\n                    <Sparkles className=\"w-4 h-4 text-purple-600 transition-transform group-hover:rotate-12\" />\n                    <span>Programar Modulaci\303\263n por IA</span>\n                  </>\n                )}\n              </button>\n\n              {aiError && (\n                <div className=\"p-3 bg-red-950/30 border border-red-900/50 rounded-xl flex items-start space-x-2 text-[11px] text-red-400\">\n                  <AlertCircle className=\"w-4 h-4 shrink-0 mt-0.5\" />\n                  <span>{aiError}</span>\n                </div>\n              )}\n\n              {/* Display currently active cognitive program */}\n              <div className=\"bg-slate-950/60 border border-slate-900/80 p-3.5 rounded-2xl\">\n                <span className=\"text-[9px] font-mono font-semibold text-cyan-400 tracking-wider\">PROGRAMA RECEPTIVO ACTIVO</span>\n                <h4 className=\"text-xs font-bold text-slate-100 mt-1 flex items-center space-x-1.5\">\n                  <span>{activeProgramName}</span>\n                </h4>\n                <p className=\"text-[11px] text-slate-400 leading-relaxed mt-1.5 italic\">\n                  &ldquo;{aiExplanation}&rdquo;\n                </p>\n              </div>\n            </div>\n          </div>\n\n          {/* SENSORY SOUND PRESETS */}\n          <div id=\"card-presets\" className=\"bg-slate-900/30 border border-slate-900 rounded-3xl p-5 backdrop-blur-md\">\n            <h3 className=\"text-xs font-bold text-slate-400 font-mono tracking-wider mb-3\">\n              PROGRAMAS PSICOAC\303\232STICOS EST\303\201NDAR\n            </h3>\n            \n            <div className=\"grid grid-cols-1 gap-2.5\">\n              {presets.map((preset) => {\n                const isActive = activeProgramName === preset.name;\n                return (\n                  <button\n                    key={preset.id}\n                    onClick={() => loadPreset(preset)}\n                    className={`p-3 rounded-2xl border text-left flex items-start space-x-3 transition duration-200 group ${\n                      isActive \n                        ? \'bg-gradient-to-r from-purple-950/50 to-slate-900/50 border-purple-500/40 text-slate-100\' \n                        : \'bg-slate-950/30 border-slate-900/60 hover:bg-slate-900/40 text-slate-300\'\n                    }`}\n                  >\n                    <div className={`p-2 rounded-xl shrink-0 mt-0.5 ${\n                      isActive ? \'bg-purple-900/50 text-purple-300\' : \'bg-slate-900 text-slate-400 group-hover:text-slate-300\'\n                    }`}>\n                      {preset.icon}\n                    </div>\n                    <div className=\"flex-1 min-w-0\">\n                      <div className=\"flex items-center justify-between\">\n                        <span className=\"text-xs font-bold font-sans tracking-tight\">{preset.name}</span>\n                        <span className=\"text-[10px] font-mono text-slate-400 font-semibold bg-slate-950/80 px-2 py-0.5 rounded-md\">{preset.range}</span>\n                      </div>\n                      <p className=\"text-[10px] text-slate-400 line-clamp-1 mt-0.5\">{preset.description}</p>\n                    </div>\n                  </button>\n                );\n              })}\n            </div>\n          </div>\n\n          {/* MANUAL TUNERS SECTION */}\n          <div id=\"card-manual-controls\" className=\"bg-slate-905 border border-slate-900 rounded-3xl p-5 backdrop-blur-md\">\n            <div className=\"flex items-center space-x-2 mb-4\">\n              <Sliders className=\"w-4 h-4 text-cyan-400\" />\n              <h3 className=\"text-sm font-semibold text-slate-200\">\n                Ajuste Fino Manual\n              </h3>\n            </div>\n\n            <div className=\"space-y-4\">\n              {/* Carrier Frequency Slider */}\n              <div>\n                <div className=\"flex justify-between items-center text-xs mb-1 font-mono text-slate-400\">\n                  <span>Frecuencia Portadora (Hz)</span>\n                  <span className=\"text-cyan-400 font-bold\">{carrierFreq} Hz</span>\n                </div>\n                <input \n                  type=\"range\" \n                  min=\"100\" \n                  max=\"350\" \n                  value={carrierFreq} \n                  onChange={(e) => {\n                    setCarrierFreq(parseInt(e.target.value));\n                    setActiveProgramName(\'Ajuste Manual Personalizado\');\n                    setAiExplanation(\'Sintonizaci\303\263n manual del oscilador portador est\303\251reo.\');\n                  }}\n                  className=\"w-full accent-cyan-500 bg-slate-850 h-1 rounded-lg cursor-pointer animate-none\"\n                />\n                <div className=\"flex justify-between text-[9px] text-slate-600 font-mono mt-1\">\n                  <span>100Hz (Graves sutiles)</span>\n                  <span>350Hz (Agudos t\303\241ctiles)</span>\n                </div>\n              </div>\n\n              {/* Binaural Pulse Slider */}\n              <div>\n                <div className=\"flex justify-between items-center text-xs mb-1 font-mono text-slate-400\">\n                  <span>Pulso Binaural Diferencial (Hz)</span>\n                  <span className=\"text-emerald-400 font-bold\">\n                    {binauralBeatFreq} Hz ({getActivePresetName(binauralBeatFreq)})\n                  </span>\n                </div>\n                <input \n                  type=\"range\" \n                  min=\"1\" \n                  max=\"45\" \n                  step=\"0.5\" \n                  value={binauralBeatFreq} \n                  onChange={(e) => {\n                    setBinauralBeatFreq(parseFloat(e.target.value));\n                    setActiveProgramName(\'Ajuste Manual Personalizado\');\n                    setAiExplanation(\'Sintonizaci\303\263n manual del pulso psicoac\303\272stico diferencial.\');\n                  }}\n                  className=\"w-full accent-emerald-500 bg-slate-850 h-1 rounded-lg cursor-pointer\"\n                />\n              </div>\n\n              {/* Wave Type Selector */}\n              <div>\n                <span className=\"text-xs text-slate-400 font-mono block mb-2\">Forma de Onda de Entrada</span>\n                <div className=\"grid grid-cols-2 gap-2\">\n                  <button \n                    onClick={() => setWaveType(\'sine\')}\n                    className={`py-1.5 px-3 rounded-xl border text-xs font-semibold font-mono transition ${\n                      waveType === \'sine\' \n                        ? \'bg-slate-900 border-cyan-500/60 text-cyan-300\' \n                        : \'bg-slate-950/40 border-slate-900 text-slate-400 hover:text-slate-300\'\n                    }`}\n                  >\n                    Senoidal Pura\n                  </button>\n                  <button \n                    onClick={() => setWaveType(\'triangle\')}\n                    className={`py-1.5 px-3 rounded-xl border text-xs font-semibold font-mono transition ${\n                      waveType === \'triangle\' \n                        ? \'bg-slate-900 border-cyan-500/60 text-cyan-300\' \n                        : \'bg-slate-950/40 border-slate-900 text-slate-400 hover:text-slate-300\'\n                    }`}\n                  >\n                    Triangular Suave\n                  </button>\n                </div>\n              </div>\n\n              {/* AMBIENT BACKGROUND MIXER */}\n              <div className=\"border-t border-slate-900/60 pt-4 mt-2\">\n                <span className=\"text-xs text-slate-400 font-mono block mb-2\">Atm\303\263sfera de Fondo Sintetizada</span>\n                \n                <div className=\"grid grid-cols-4 gap-1.5 mb-3.5\">\n                  {[\n                    { id: \'none\', label: \'Muto\' },\n                    { id: \'pink\', label: \'Static\' },\n                    { id: \'brown\', label: \'Tierra\' },\n                    { id: \'cosmic\', label: \'C\303\263smico\' },\n                  ].map((amb) => (\n                    <button\n                      key={amb.id}\n                      onClick={() => setAmbientType(amb.id)}\n                      className={`py-1 rounded-lg text-[10px] font-bold font-mono border transition ${\n                        ambientType === amb.id \n                          ? \'bg-purple-900/20 border-purple-500/50 text-purple-300\' \n                          : \'bg-slate-950/40 border-slate-900 text-slate-400 hover:text-slate-300\'\n                      }`}\n                    >\n                      {amb.label}\n                    </button>\n                  ))}\n                </div>\n\n                {ambientType !== \'none\' && (\n                  <div>\n                    <div className=\"flex justify-between items-center text-[10px] mb-1 font-mono text-slate-500\">\n                      <span>Mezcla de Fondo</span>\n                      <span>{Math.round(ambientVolume * 100)}%</span>\n                    </div>\n                    <input \n                      type=\"range\" \n                      min=\"0\" \n                      max=\"100\" \n                      value={ambientVolume * 100} \n                      onChange={(e) => setAmbientVolume(parseInt(e.target.value) / 100)}\n                      className=\"w-full accent-purple-500 bg-slate-850 h-1 rounded-lg cursor-pointer\"\n                    />\n                  </div>\n                )}\n              </div>\n            </div>\n          </div>\n\n        </section>\n\n      </main>\n\n      {/* SCIENTIFIC HUD FOOTER */}\n      <footer id=\"dashboard-footer\" className=\"border-t border-slate-900 bg-slate-950/50 py-4 px-4 font-mono text-[10px] text-slate-500 mt-auto\">\n        <div className=\"max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-2\">\n          <span>PORT PORTAL OUT: D\303\211CADA-2026 AUDIOLAB SYSTEM</span>\n          <span>ESTADOS ENTR\303\211IN: DELTA / THETA / ALFA / BETA / GAMMA</span>\n          <span>GENERADO ENTERAMENTE MEDIANTE RESPUESTAS DIRECTAS LOCALES</span>\n        </div>\n      </footer>\n    </div>\n  );\n}\n\n// Simple state calculation helper\nfunction isWithModulationProgress(isModulation: boolean, secs: number) {\n  return isModulation && secs > 0;\n}\n"
    }
