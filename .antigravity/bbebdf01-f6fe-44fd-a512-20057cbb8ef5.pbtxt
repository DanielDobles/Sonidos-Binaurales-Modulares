        }
        lines {
          text: "  const currentActualCarrier = Math.max(80, carrierFreq + (isModulationEnabled ? modulationSteps[currentModStep].carrierOffset : 0));"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
