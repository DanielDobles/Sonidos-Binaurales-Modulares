          text: "      description: \'Enfoque ejecutivo acelerado, razonamiento anal\303\255tico, resoluci\303\263n de problemas complejos.\',"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      icon: <Zap className=\"w-4 h-4\" /> "
