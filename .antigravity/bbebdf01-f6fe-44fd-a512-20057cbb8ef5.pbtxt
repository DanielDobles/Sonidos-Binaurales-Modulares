        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Configure frequencies instantly from Gemini JSON suggestion"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      setCarrierFreq(program.baseCarrierFrequency);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      setBinauralBeatFreq(program.binauralBeatFrequency);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      setActiveProgramName(program.sessionName);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      setAiExplanation(program.explanation);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
