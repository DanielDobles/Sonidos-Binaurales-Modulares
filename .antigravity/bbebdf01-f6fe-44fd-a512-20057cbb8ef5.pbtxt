        }
        lines {
          text: "    if (audioCtx.state === \'suspended\') {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      await audioCtx.resume();"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
