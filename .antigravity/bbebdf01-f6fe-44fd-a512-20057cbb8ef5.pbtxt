          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      setSecondsRemaining(30);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Auto assign ambient"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const ambType = program.suggestedAmbient.toLowerCase();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      if (ambType.includes(\'marr\303\263n\') || ambType.includes(\'brown\')) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        setAmbientType(\'brown\');"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      } else if (ambType.includes(\'rosa\') || ambType.includes(\'pink\')) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        setAmbientType(\'pink\');"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      } else if (ambType.includes(\'cosm\') || ambType.includes(\'viento\') || ambType.includes(\'espacio\')) {"
