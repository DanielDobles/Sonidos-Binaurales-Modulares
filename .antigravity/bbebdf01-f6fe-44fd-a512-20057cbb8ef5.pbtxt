    replacement_chunks {
      target_content: "  return (\n    <div id=\"psychoacoustic-dashboard\" className=\"min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans selection:bg-purple-900 selection:text-white\">\n      \n      {/* HEADER SECTION */}\n      <header id=\"dashboard-header\" className=\"border-b border-slate-900 bg-slate-950/80 backdrop-blur-md sticky top-0 z-40\">\n        <div className=\"max-w-6xl mx-auto px-4 py-4 flex items-center justify-between\">\n          <div className=\"flex items-center space-x-3\">\n            <div className=\"bg-gradient-to-tr from-purple-600 to-cyan-500 p-2.5 rounded-xl shadow-lg ring-1 ring-white/10\">\n              <Activity className=\"w-5 h-5 text-white animate-pulse\" />\n            </div>\n            <div>\n              <h1 className=\"text-xl font-bold tracking-tight bg-gradient-to-r from-white via-slate-200 to-slate-400 bg-clip-text text-transparent\">\n                Sonidos Binaurales Modulares\n              </h1>\n              <p className=\"text-xs text-slate-500 font-mono tracking-wider\">\n                NEURO-ENTRAINMENT ENGINE ESP \342\200\242 PSICOAC\303\232STICA ACTIVA\n              </p>\n            </div>\n          </div>\n          \n          <div className=\"flex items-center space-x-4\">\n            {isPlaying ? (\n              <span className=\"flex items-center space-x-2 text-xs font-mono px-3 py-1.5 rounded-full bg-emerald-500/10 text-emerald-400 ring-1 ring-emerald-500/20\">\n                <span className=\"w-2 h-2 rounded-full bg-emerald-500 animate-ping\" />\n                <span>ACOPLAMIENTO ACTIVO</span>\n              </span>\n            ) : (\n              <span className=\"text-xs font-mono px-3 py-1.5 rounded-full bg-slate-900 text-slate-400 border border-slate-800\">\n                SINTETIZADOR SILENCIADO\n              </span>\n            )}\n          </div>\n        </div>\n      </header>\n\n      {/* MAIN CONTAINER */}\n      <main id=\"dashboard-main\" className=\"flex-1 max-w-6xl w-full mx-auto p-4 grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch\">\n        \n        {/* LEFT COLUMN: VISUALIZATION & MODULATION TIMELINE (Span 7) */}\n        <section id=\"column-left\" className=\"lg:col-span-7 flex flex-col gap-6\">\n          \n          {/* STEREOPHONIC WAVE VISUALIZER CARD */}\n          <div id=\"card-visualizer\" className=\"bg-slate-900/60 border border-slate-900 rounded-3xl p-5 flex flex-col justify-between overflow-hidden relative group backdrop-blur-md\">\n            <div className=\"flex justify-between items-center mb-3\">\n              <div className=\"flex items-center space-x-2\">\n                <Activity className=\"w-4 h-4 text-cyan-400\" />\n                <h2 className=\"text-sm font-semibold text-slate-200 tracking-wide\">\n                  Visualizador Hemisf\303\251rico Est\303\251reo en Vivo\n                </h2>\n              </div>\n              <div className=\"text-[10px] font-mono text-slate-400 bg-slate-950 px-2.5 py-1 rounded-md border border-slate-800/60\">\n                {waveType === \'sine\' ? \'SENOIDAL PURA\' : \'TRIANGULAR COGNITIVA\'}\n              </div>\n            </div>\n\n            {/* Simulated stereo oscilloscopes inside html5 high fidelity performance canvas */}\n            <div className=\"relative w-full h-56 bg-slate-950 rounded-2xl overflow-hidden border border-slate-800/50\">\n              <canvas \n                ref={canvasRef} \n                width={650} \n                height={224} \n                className=\"w-full h-full block\" \n              />\n              \n              {/* Overlay shadow borders */}\n              <div className=\"absolute inset-x-0 top-0 h-4 bg-gradient-to-b from-slate-950 to-transparent pointer-events-none\" />\n              <div className=\"absolute inset-x-0 bottom-0 h-4 bg-gradient-to-t from-slate-950 to-transparent pointer-events-none\" />\n            </div>\n\n            <div className=\"mt-4 flex items-center justify-between text-xs text-slate-400 font-mono\">\n              <div className=\"flex items-center space-x-2\">\n                <div className=\"w-2.5 h-2.5 rounded-sm bg-emerald-500\" />\n                <span>O\303\255do Izquierdo (-)</span>\n              </div>\n              <div className=\"flex items-center space-x-2\">\n                <div className=\"w-2.5 h-2.5 rounded-sm bg-indigo-500\" />\n                <span>O\303\255do Derecho (+)</span>\n              </div>\n              <div className=\"flex items-center space-x-1 text-slate-500\">\n                <Info className=\"w-3.5 h-3.5\" />\n                <span>Usa auriculares para percibir el efecto.</span>\n              </div>\n            </div>\n          </div>\n\n          {/* 30-SECOND ANTI-ADAPTATION ENGINE TIMELINE */}\n          <div id=\"card-modulation-timeline\" className=\"bg-slate-900/60 border border-slate-900 rounded-3xl p-6 relative backdrop-blur-md\">\n            <div className=\"flex items-center justify-between mb-4\">\n              <div className=\"flex items-center space-x-2\">\n                <RefreshCw className=\"w-4 h-4 text-purple-400 animate-spin\" style={{ animationDuration: \'10s\' }} />\n                <div>\n                  <h3 className=\"text-sm font-semibold text-slate-200\">\n                    Bucle Modular Anti-Adaptaci\303\263n Clic-Prohibido\n                  </h3>\n                  <p className=\"text-xs text-slate-500\">Secuencia din\303\241mica de arrastre cada 30 segundos</p>\n                </div>\n              </div>\n\n              <div className=\"flex items-center space-x-3\">\n                <div className=\"flex items-center\">\n                  <label htmlFor=\"modulation-toggle\" className=\"sr-only\">Activar Auto-Modulaci\303\263n</label>\n                  <button \n                    id=\"modulation-toggle\"\n                    onClick={() => {\n                      setIsModulationEnabled(!isModulationEnabled);\n                      setSecondsRemaining(30);\n                    }}\n                    className={`relative inline-flex h-6 w-11 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 focus:ring-offset-slate-950 ${isModulationEnabled ? \'bg-purple-600\' : \'bg-slate-800\'}`}\n                  >\n                    <span\n                      className={`pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out ${isModulationEnabled ? \'translate-x-5\' : \'translate-x-0\'}`}\n                    />\n                  </button>\n                </div>\n                <span className=\"text-xs font-mono font-medium text-slate-300\">\n                  {isModulationEnabled ? \'ACTIVADO\' : \'CONGELADO\'}\n                </span>\n              </div>\n            </div>\n\n            {/* Time interval dynamic indicator bar */}\n            <div className=\"bg-slate-950 p-4 rounded-2xl border border-slate-800/80 mb-5 relative overflow-hidden flex items-center justify-between\">\n              <div className=\"z-10\">\n                <span className=\"text-[10px] font-mono text-purple-400 tracking-wider\">FASE ACTUAL EN CURSO ({currentModStep + 1}/6)</span>\n                <h4 className=\"text-base font-bold text-slate-100 mt-0.5\">\n                  {modulationSteps[currentModStep]?.stepName || \'Modulaci\303\263n de Fase\'}\n                </h4>\n                <div className=\"flex space-x-4 mt-2 text-xs font-mono text-slate-400\">\n                  <span>Desv. Portadora: <strong className=\"text-cyan-400\">{modulationSteps[currentModStep]?.carrierOffset >= 0 ? `+${modulationSteps[currentModStep]?.carrierOffset}` : modulationSteps[currentModStep]?.carrierOffset} Hz</strong></span>\n                  <span>Desv. Pulso: <strong className=\"text-emerald-400\">{modulationSteps[currentModStep]?.beatOffset >= 0 ? `+${modulationSteps[currentModStep]?.beatOffset}` : modulationSteps[currentModStep]?.beatOffset} Hz</strong></span>\n                </div>\n              </div>\n\n              <div className=\"flex flex-col items-end z-10\">\n                <span className=\"text-[10px] font-mono text-slate-500\">SIGUIENTE CORRECCI\303\223N</span>\n                <span className=\"text-3xl font-extrabold font-mono text-slate-50 tracking-tight\">\n                  0:{secondsRemaining < 10 ? `0${secondsRemaining}` : secondsRemaining}\n                </span>\n              </div>\n\n              {/* Progress linear bar overlay inside background */}\n              {isWithModulationProgress(isModulationEnabled, secondsRemaining) && (\n                <div \n                  className=\"absolute bottom-0 left-0 h-1 bg-gradient-to-r from-purple-600 to-cyan-500 transition-all duration-1000 ease-linear\"\n                  style={{ width: `${((30 - secondsRemaining) / 30) * 100}%` }}\n                />\n              )}\n            </div>\n\n            {/* Modulation Grid List */}\n            <div className=\"grid grid-cols-2 sm:grid-cols-3 gap-3\">\n              {modulationSteps.map((step, index) => {\n                const isActive = index === currentModStep && isModulationEnabled;\n                return (\n                  <div \n                    key={index}\n                    className={`p-3 rounded-xl border text-left transition-all duration-300 ${\n                      isActive \n                        ? \'bg-purple-950/40 border-purple-500/60 ring-1 ring-purple-500/20\' \n                        : \'bg-slate-950/40 border-slate-900/60 text-slate-400\'\n                    }`}\n                  >\n                    <div className=\"flex items-center justify-between mb-1.5\">\n                      <span className=\"text-[9px] font-mono text-slate-500\">ETAPA 0{index + 1}</span>\n                      {isActive && <span className=\"w-1.5 h-1.5 rounded-full bg-purple-400 animate-ping\" />}\n                    </div>\n                    <div className=\"text-xs font-semibold truncate text-slate-200\">\n                      {step.stepName}\n                    </div>\n                    <div className=\"grid grid-cols-2 gap-1 mt-2 text-[10px] font-mono text-slate-400\">\n                      <div>Port: {step.carrierOffset >= 0 ? `+${step.carrierOffset}` : step.carrierOffset}Hz</div>\n                      <div>Beat: {step.beatOffset >= 0 ? `+${step.beatOffset}` : step.beatOffset}Hz</div>\n                    </div>\n                  </div>\n                );\n              })}\n            </div>\n\n            <p className=\"text-[11px] text-slate-500 mt-4 leading-relaxed bg-slate-950/30 p-3 rounded-xl border border-slate-900/40\">\n              \360\237\222\241 <strong>\302\277Por qu\303\251 cambiar cada 30 segundos?</strong> Para contrarrestar la adaptaci\303\263n sensorial del c\303\263rtex auditivo primario. Al deslizar micromodulaciones sutiles, el cerebro se mantiene activamente sincronizado en este intervalo constante, maximizando la efectividad curativa u optimizadora.\n            </p>\n          </div>\n\n        </section>\n\n        {/* RIGHT COLUMN: MANUAL FREQUENCY ENGINE & IA SESSION ARCHITECT (Span 5) */}\n        <section id=\"column-right\" className=\"lg:col-span-5 flex flex-col gap-6\">\n          \n          {/* CONTROL MASTER POWER & GENERAL GAIN */}\n          <div id=\"card-master-power\" className=\"bg-gradient-to-b from-slate-900 to-slate-950 border border-slate-900 rounded-3xl p-6 text-center shadow-xl relative overflow-hidden\">\n            <div className=\"absolute right-0 top-0 translate-x-12 -translate-y-12 w-44 h-44 bg-purple-600/10 rounded-full blur-2xl\" />\n            <div className=\"absolute left-0 bottom-0 -translate-x-12 translate-y-12 w-44 h-44 bg-cyan-500/10 rounded-full blur-2xl\" />\n\n            <div className=\"relative z-10\">\n              <button \n                onClick={runSoundEngine}\n                className={`w-20 h-20 rounded-full flex items-center justify-center mx-auto transition-all duration-500 hover:scale-105 active:scale-95 shadow-2xl ${\n                  isPlaying \n                    ? \'bg-gradient-to-tr from-red-600 to-amber-500 text-white ring-4 ring-red-500/30 shadow-red-500/20\' \n                    : \'bg-gradient-to-tr from-purple-600 to-cyan-500 text-white ring-4 ring-purple-600/30 shadow-purple-500/20\'\n                }`}\n              >\n                {isPlaying ? <Pause className=\"w-8 h-8 fill-white\" /> : <Play className=\"w-8 h-8 fill-white translate-x-0.5\" />}\n              </button>\n\n              <h2 className=\"text-lg font-bold text-slate-100 mt-4 leading-none\">\n                {isPlaying ? \'Silenciar Prescripci\303\263n\' : \'Activar Sonidos Binaurales\'}\n              </h2>\n              <p className=\"text-xs text-slate-400 mt-1.5 font-mono\">\n                {isPlaying \n                  ? `TRANSMITIENDO EN VIVO A Freq real: ${currentActualCarrier.toFixed(1)}Hz` \n                  : \'SINTETIZADOR DIGITAL DE AUDIO LISTO\'}\n              </p>\n\n              {/* Master Volume Slider */}\n              <div className=\"mt-5 max-w-sm mx-auto\">\n                <div className=\"flex justify-between items-center text-xs mb-1 font-mono text-slate-400\">\n                  <div className=\"flex items-center space-x-1.5\">\n                    <Volume2 className=\"w-4 h-4 text-purple-400\" />\n                    <span>Volumen General</span>\n                  </div>\n                  <span>{Math.round(masterVolume * 100)}%</span>\n                </div>\n                <input \n                  type=\"range\" \n                  min=\"0\" \n                  max=\"100\" \n                  value={masterVolume * 100} \n                  onChange={(e) => setMasterVolume(parseInt(e.target.value) / 100)}\n                  className=\"w-full accent-purple-500 bg-slate-850 h-1.5 rounded-lg cursor-pointer\"\n                />\n              </div>\n            </div>\n          </div>\n\n          {/* AI MIND PROGRAM ARCHITECT PANEL (Gemini integration) */}\n          <div id=\"card-ai-designer\" className=\"bg-slate-900/60 border border-slate-900 rounded-3xl p-5 backdrop-blur-md relative overflow-hidden\">\n            <div className=\"absolute right-3 top-3\">\n              <Sparkles className=\"w-5 h-5 text-purple-400/80 animate-pulse\" />\n            </div>\n\n            <div className=\"flex items-center space-x-2 mb-3\">\n              <Brain className=\"w-4 h-4 text-purple-400\" />\n              <h3 className=\"text-sm font-semibold text-slate-200\">\n                Dise\303\261ador de Frecuencias con IA (Gemini 3.5)\n              </h3>\n            </div>\n\n            <div className=\"space-y-4\">\n              <p className=\"text-xs text-slate-400 leading-relaxed\">\n                Describe tu estado actual, nivel de ansiedad o tu meta cognitiva. La IA recalcular\303\241 cient\303\255ficamente las frecuencias base, el desv\303\255o adaptativo y los bucles ideales.\n              </p>\n\n              <div>\n                <textarea \n                  value={aiPrompt}\n                  onChange={(e) => setAiPrompt(e.target.value)}\n                  placeholder=\"Ej: Tengo que estudiar c\303\241lculo complejo por 3h. Siento fatiga mental y estr\303\251s moderado...\"\n                  rows={2}\n                  className=\"w-full text-slate-200 placeholder:text-slate-500 bg-slate-950 border border-slate-850 rounded-2xl p-3 focus:outline-none focus:ring-1 focus:ring-purple-500 text-xs resize-none\"\n                />\n              </div>\n\n              <button \n                onClick={launchAiArchitect}\n                disabled={isAiLoading || !aiPrompt.trim()}\n                className=\"w-full bg-slate-100 hover:bg-white text-slate-950 hover:text-black font-semibold text-xs py-2.5 px-4 rounded-xl transition duration-200 flex items-center justify-center space-x-2 disabled:bg-slate-800 disabled:text-slate-500 disabled:cursor-not-allowed group\"\n              >\n                {isAiLoading ? (\n                  <>\n                    <RefreshCw className=\"w-4 h-4 animate-spin text-slate-950\" />\n                    <span>Calculando Neuro-Prescripci\303\263n...</span>\n                  </>\n                ) : (\n                  <>\n                    <Sparkles className=\"w-4 h-4 text-purple-600 transition-transform group-hover:rotate-12\" />\n                    <span>Programar Modulaci\303\263n por IA</span>\n                  </>\n                )}\n              </button>\n\n              {aiError && (\n                <div className=\"p-3 bg-red-950/30 border border-red-900/50 rounded-xl flex items-start space-x-2 text-[11px] text-red-400\">\n                  <AlertCircle className=\"w-4 h-4 shrink-0 mt-0.5\" />\n                  <span>{aiError}</span>\n                </div>\n              )}\n\n              {/* Display currently active cognitive program */}\n              <div className=\"bg-slate-950/60 border border-slate-900/80 p-3.5 rounded-2xl\">\n                <span className=\"text-[9px] font-mono font-semibold text-cyan-400 tracking-wider\">PROGRAMA RECEPTIVO ACTIVO</span>\n                <h4 className=\"text-xs font-bold text-slate-100 mt-1 flex items-center space-x-1.5\">\n                  <span>{activeProgramName}</span>\n                </h4>\n                <p className=\"text-[11px] text-slate-400 leading-relaxed mt-1.5 italic\">\n                  &ldquo;{aiExplanation}&rdquo;\n                </p>\n              </div>\n            </div>\n          </div>\n\n          {/* SENSORY SOUND PRESETS */}\n          <div id=\"card-presets\" className=\"bg-slate-900/30 border border-slate-900 rounded-3xl p-5 backdrop-blur-md\">\n            <h3 className=\"text-xs font-bold text-slate-400 font-mono tracking-wider mb-3\">\n              PROGRAMAS PSICOAC\303\232STICOS EST\303\201NDAR\n            </h3>\n            \n            <div className=\"grid grid-cols-1 gap-2.5\">\n              {presets.map((preset) => {\n                const isActive = activeProgramName === preset.name;\n                return (\n                  <button\n                    key={preset.id}\n                    onClick={() => loadPreset(preset)}\n                    className={`p-3 rounded-2xl border text-left flex items-start space-x-3 transition duration-200 group ${\n                      isActive \n                        ? \'bg-gradient-to-r from-purple-950/50 to-slate-900/50 border-purple-500/40 text-slate-100\' \n                        : \'bg-slate-950/30 border-slate-900/60 hover:bg-slate-900/40 text-slate-300\'\n                    }`}\n                  >\n                    <div className={`p-2 rounded-xl shrink-0 mt-0.5 ${\n                      isActive ? \'bg-purple-900/50 text-purple-300\' : \'bg-slate-900 text-slate-400 group-hover:text-slate-300\'\n                    }`}>\n                      {preset.icon}\n                    </div>\n                    <div className=\"flex-1 min-w-0\">\n                      <div className=\"flex items-center justify-between\">\n                        <span className=\"text-xs font-bold font-sans tracking-tight\">{preset.name}</span>\n                        <span className=\"text-[10px] font-mono text-slate-400 font-semibold bg-slate-950/80 px-2 py-0.5 rounded-md\">{preset.range}</span>\n                      </div>\n                      <p className=\"text-[10px] text-slate-400 line-clamp-1 mt-0.5\">{preset.description}</p>\n                    </div>\n                  </button>\n                );\n              })}\n            </div>\n          </div>\n\n          {/* MANUAL TUNERS SECTION */}\n          <div id=\"card-manual-controls\" className=\"bg-slate-905 border border-slate-900 rounded-3xl p-5 backdrop-blur-md\">\n            <div className=\"flex items-center space-x-2 mb-4\">\n              <Sliders className=\"w-4 h-4 text-cyan-400\" />\n              <h3 className=\"text-sm font-semibold text-slate-200\">\n                Ajuste Fino Manual\n              </h3>\n            </div>\n\n            <div className=\"space-y-4\">\n              {/* Carrier Frequency Slider */}\n              <div>\n                <div className=\"flex justify-between items-center text-xs mb-1 font-mono text-slate-400\">\n                  <span>Frecuencia Portadora (Hz)</span>\n                  <span className=\"text-cyan-400 font-bold\">{carrierFreq} Hz</span>\n                </div>\n                <input \n                  type=\"range\" \n                  min=\"100\" \n                  max=\"350\" \n                  value={carrierFreq} \n                  onChange={(e) => {\n                    setCarrierFreq(parseInt(e.target.value));\n                    setActiveProgramName(\'Ajuste Manual Personalizado\');\n                    setAiExplanation(\'Sintonizaci\303\263n manual del oscilador portador est\303\251reo.\');\n                  }}\n                  className=\"w-full accent-cyan-500 bg-slate-850 h-1 rounded-lg cursor-pointer animate-none\"\n                />\n                <div className=\"flex justify-between text-[9px] text-slate-600 font-mono mt-1\">\n                  <span>100Hz (Graves sutiles)</span>\n                  <span>350Hz (Agudos t\303\241ctiles)</span>\n                </div>\n              </div>\n\n              {/* Binaural Pulse Slider */}\n              <div>\n                <div className=\"flex justify-between items-center text-xs mb-1 font-mono text-slate-400\">\n                  <span>Pulso Binaural Diferencial (Hz)</span>\n                  <span className=\"text-emerald-400 font-bold\">\n                    {binauralBeatFreq} Hz ({getActivePresetName(binauralBeatFreq)})\n                  </span>\n                </div>\n                <input \n                  type=\"range\" \n                  min=\"1\" \n                  max=\"45\" \n                  step=\"0.5\" \n                  value={binauralBeatFreq} \n                  onChange={(e) => {\n                    setBinauralBeatFreq(parseFloat(e.target.value));\n                    setActiveProgramName(\'Ajuste Manual Personalizado\');\n                    setAiExplanation(\'Sintonizaci\303\263n manual del pulso psicoac\303\272stico diferencial.\');\n                  }}\n                  className=\"w-full accent-emerald-500 bg-slate-100 h-1 rounded-lg cursor-pointer\"\n                />\n              </div>\n\n              {/* Wave Type Selector */}\n              <div>\n                <span className=\"text-xs text-slate-400 font-mono block mb-2\">Forma de Onda de Entrada</span>\n                <div className=\"grid grid-cols-2 gap-2\">\n                  <button \n                    onClick={() => setWaveType(\'sine\')}\n                    className={`py-1.5 px-3 rounded-xl border text-xs font-semibold font-mono transition ${\n                      waveType === \'sine\' \n                        ? \'bg-slate-900 border-cyan-500/60 text-cyan-300\' \n                        : \'bg-slate-950/40 border-slate-900 text-slate-400 hover:text-slate-300\'\n                    }`}\n                  >\n                    Senoidal Pura\n                  </button>\n                  <button \n                    onClick={() => setWaveType(\'triangle\')}\n                    className={`py-1.5 px-3 rounded-xl border text-xs font-semibold font-mono transition ${\n                      waveType === \'triangle\' \n                        ? \'bg-slate-900 border-cyan-500/60 text-cyan-300\' \n                        : \'bg-slate-950/40 border-slate-900 text-slate-400 hover:text-slate-300\'\n                    }`}\n                  >\n                    Triangular Suave\n                  </button>\n                </div>\n              </div>\n\n              {/* AMBIENT BACKGROUND MIXER */}\n              <div className=\"border-t border-slate-900/60 pt-4 mt-2\">\n                <span className=\"text-xs text-slate-400 font-mono block mb-1\">Atm\303\263sfera de Fondo Sintetizada</span>\n                <span className=\"text-[10px] text-slate-500 font-sans block mb-2 leading-tight\">\n                  Desactivada por preferencia para sostener estimulaci\303\263n cl\303\255nica de tonos puros y evitar fatiga.\n                </span>\n                \n                <div className=\"grid grid-cols-4 gap-1.5 mb-2\">\n                  {[\n                    { id: \'none\', label: \'Muto (Puro)\' },\n                    { id: \'pink\', label: \'Est\303\241tico\' },\n                    { id: \'brown\', label: \'Tierra\' },\n                    { id: \'cosmic\', label: \'C\303\263smico\' },\n                  ].map((amb) => (\n                    <button\n                      key={amb.id}\n                      onClick={() => setAmbientType(amb.id)}\n                      className={`py-1 rounded-lg text-[10px] font-bold font-mono border transition ${\n                        ambientType === amb.id \n                          ? \'bg-purple-900/20 border-purple-500/50 text-purple-300\' \n                          : \'bg-slate-950/40 border-slate-900 text-slate-400 hover:text-slate-300\'\n                      }`}\n                    >\n                      {amb.label}\n                    </button>\n                  ))}\n                </div>\n\n                {ambientType !== \'none\' ? (\n                  <div>\n                    <div className=\"flex justify-between items-center text-[10px] mb-1 font-mono text-slate-500\">\n                      <span>Mezcla de Fondo Activada</span>\n                      <span>{Math.round(ambientVolume * 100)}%</span>\n                    </div>\n                    <input \n                      type=\"range\" \n                      min=\"0\" \n                      max=\"100\" \n                      value={ambientVolume * 100} \n                      onChange={(e) => setAmbientVolume(parseInt(e.target.value) / 100)}\n                      className=\"w-full accent-purple-500 bg-slate-850 h-1 rounded-lg cursor-pointer\"\n                    />\n                  </div>\n                ) : (\n                  <div className=\"bg-emerald-950/20 border border-emerald-900/30 text-[10px] text-emerald-400 px-2.5 py-1.5 rounded-xl font-mono mt-1 flex items-center justify-between\">\n                    <span>ONDA PURA ACTIVA</span>\n                    <span>SIN RUIDO</span>\n                  </div>\n                )}\n              </div>\n            </div>\n          </div>\n\n        </section>\n\n      </main>\n\n      {/* SCIENTIFIC HUD FOOTER */}\n      <footer id=\"dashboard-footer\" className=\"border-t border-slate-900 bg-slate-950/50 py-4 px-4 font-mono text-[10px] text-slate-500 mt-auto\">\n        <div className=\"max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-2\">\n          <span>PORT PORTAL OUT: D\303\211CADA-2026 AUDIOLAB SYSTEM</span>\n          <span>ESTADOS ENTR\303\211IN: DELTA / THETA / ALFA / BETA / GAMMA</span>\n          <span>GENERADO ENTERAMENTE MEDIANTE RESPUESTAS DIRECTAS LOCALES</span>\n        </div>\n      </footer>\n    </div>\n  );\n}\n\n// Simple state calculation helper\nfunction isWithModulationProgress(isModulation: boolean, secs: number) {\n  return isModulation && secs > 0;\n}"
      replacement_content: "  return (\n    <div id=\"psychoacoustic-dashboard\" className=\"min-h-screen bg-slate-950 text-slate-100 flex items-center justify-center p-4 sm:p-6 font-sans selection:bg-purple-900 selection:text-white\">\n      <div className=\"w-full max-w-4xl bg-slate-900/40 border border-slate-900 rounded-3xl p-6 backdrop-blur-xl flex flex-col gap-6\">\n        \n        {/* Row 1: Active visualizer & Live state HUD */}\n        <div className=\"flex flex-col gap-3\">\n          <div className=\"flex items-center justify-between\">\n            <span className=\"text-[11px] font-mono tracking-wider text-slate-400 flex items-center gap-2\">\n              <span className={`w-2 h-2 rounded-full ${isPlaying ? \'bg-emerald-500 animate-pulse\' : \'bg-slate-700\'}`} />\n              {isPlaying \n                ? `TONO ACTIVO: ${currentActualCarrier.toFixed(1)}Hz` \n                : \'SINTETIZADOR DETENIDO\'}\n            </span>\n            <div className=\"flex items-center gap-4 text-[11px] font-mono\">\n              <span className=\"text-slate-400\">\n                PULSO: <strong className=\"text-emerald-400\">{currentActualBeat.toFixed(1)} Hz</strong> ({getActivePresetName(currentActualBeat)})\n              </span>\n              {isModulationEnabled && (\n                <span className=\"text-purple-400/80\">\n                  AUTO-MODULACI\303\223N: {secondsRemaining}s\n                </span>\n              )}\n            </div>\n          </div>\n\n          {/* HTML5 Canvas Visualizer */}\n          <div className=\"relative w-full h-56 bg-slate-950 rounded-2xl overflow-hidden border border-slate-900/60\">\n            <canvas \n              ref={canvasRef} \n              width={750} \n              height={224} \n              className=\"w-full h-full block\" \n            />\n          </div>\n        </div>\n\n        {/* Row 2: Clinical selectors */}\n        <div className=\"grid grid-cols-5 gap-2\">\n          {presets.map((preset) => {\n            const isActive = activeProgramName === preset.name || \n              (activeProgramName.includes(\'Manual\') && getActivePresetName(binauralBeatFreq).startsWith(preset.name.replace(\'Ondas \', \'\')));\n            return (\n              <button\n                key={preset.id}\n                onClick={() => loadPreset(preset)}\n                className={`py-2 px-1 rounded-xl border text-center transition duration-200 ${\n                  isActive \n                    ? \'bg-purple-950/40 border-purple-500/50 text-purple-200\' \n                    : \'bg-slate-950/20 border-slate-900 text-slate-400 hover:text-slate-200 hover:border-slate-800\'\n                }`}\n              >\n                <div className=\"text-[10px] font-bold font-mono\">{preset.name.toUpperCase()}</div>\n                <div className=\"text-[9px] font-mono opacity-60 mt-0.5\">{preset.range}</div>\n              </button>\n            );\n          })}\n        </div>\n\n        {/* Row 3: Grid division for central master control, sliders & IA designer */}\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6 items-start\">\n          \n          {/* Controls & sliders */}\n          <div className=\"space-y-4\">\n            \n            {/* Master control row */}\n            <div className=\"flex items-center gap-4 bg-slate-950/40 border border-slate-900/60 p-4 rounded-2xl\">\n              <button \n                onClick={runSoundEngine}\n                className={`w-14 h-14 rounded-full flex items-center justify-center shrink-0 transition md:hover:scale-105 active:scale-95 ${\n                  isPlaying \n                    ? \'bg-red-600 hover:bg-red-500 text-white\' \n                    : \'bg-purple-600 hover:bg-purple-500 text-white\'\n                }`}\n              >\n                {isPlaying ? <Pause className=\"w-5 h-5 fill-white\" /> : <Play className=\"w-5 h-5 fill-white translate-x-0.5\" />}\n              </button>\n              <div className=\"flex-1\">\n                <div className=\"flex justify-between items-center text-xs font-mono text-slate-400 mb-1\">\n                  <span>VOLUMEN GENERAL</span>\n                  <span>{Math.round(masterVolume * 100)}%</span>\n                </div>\n                <input \n                  type=\"range\" \n                  min=\"0\" \n                  max=\"100\" \n                  value={masterVolume * 100} \n                  onChange={(e) => setMasterVolume(parseInt(e.target.value) / 100)}\n                  className=\"w-full accent-purple-500 bg-slate-850 h-1 rounded-lg cursor-pointer\"\n                />\n              </div>\n            </div>\n\n            {/* Carrier manual slider */}\n            <div className=\"bg-slate-950/20 border border-slate-900/60 p-4 rounded-2xl space-y-3\">\n              <div>\n                <div className=\"flex justify-between items-center text-xs font-mono text-slate-400 mb-1\">\n                  <span>PORTADORA (FRECUENCIA BASE)</span>\n                  <span className=\"text-cyan-400 font-bold\">{carrierFreq} Hz</span>\n                </div>\n                <input \n                  type=\"range\" \n                  min=\"100\" \n                  max=\"350\" \n                  value={carrierFreq} \n                  onChange={(e) => {\n                    setCarrierFreq(parseInt(e.target.value));\n                    setActiveProgramName(\'Ajuste Manual Personalizado\');\n                    setAiExplanation(\'Sintonizaci\303\263n manual del oscilador portador est\303\251reo.\');\n                  }}\n                  className=\"w-full accent-cyan-500 bg-slate-850 h-1 rounded-lg cursor-pointer\"\n                />\n              </div>\n\n              {/* Binaural differential manual slider */}\n              <div>\n                <div className=\"flex justify-between items-center text-xs font-mono text-slate-400 mb-1\">\n                  <span>PULSO BINAURAL MANUAL</span>\n                  <span className=\"text-emerald-400 font-bold\">{binauralBeatFreq} Hz</span>\n                </div>\n                <input \n                  type=\"range\" \n                  min=\"1\" \n                  max=\"45\" \n                  step=\"0.5\" \n                  value={binauralBeatFreq} \n                  onChange={(e) => {\n                    setBinauralBeatFreq(parseFloat(e.target.value));\n                    setActiveProgramName(\'Ajuste Manual Personalizado\');\n                    setAiExplanation(\'Sintonizaci\303\263n manual del pulso psicoac\303\272stico diferencial.\');\n                  }}\n                  className=\"w-full accent-emerald-500 bg-slate-850 h-1 rounded-lg cursor-pointer\"\n                />\n              </div>\n\n              {/* Modulation mode switch and step info */}\n              <div className=\"flex items-center justify-between pt-2 border-t border-slate-900\">\n                <span className=\"text-[10px] font-mono text-slate-400\">MICRO-VARIACIONES</span>\n                <div className=\"flex items-center gap-2\">\n                  <button \n                    onClick={() => {\n                      setIsModulationEnabled(!isModulationEnabled);\n                      setSecondsRemaining(30);\n                    }}\n                    className={`text-[10px] font-mono px-2.5 py-1 rounded border transition ${\n                      isModulationEnabled \n                        ? \'bg-purple-950/30 border-purple-500/40 text-purple-300\' \n                        : \'border-slate-800 text-slate-500\'\n                    }`}\n                  >\n                    {isModulationEnabled ? \'ACTIVA (30S)\' : \'PAUSADA\'}\n                  </button>\n                </div>\n              </div>\n            </div>\n\n          </div>\n\n          {/* AI Session programmer input area */}\n          <div className=\"bg-slate-950/30 border border-slate-900 rounded-2xl p-4 flex flex-col justify-between h-full min-h-[200px]\">\n            <div className=\"space-y-3\">\n              <span className=\"text-[10px] font-mono text-purple-400 tracking-wider\">DISE\303\221ADOR POR IA</span>\n              <div className=\"flex gap-2\">\n                <input \n                  type=\"text\"\n                  value={aiPrompt}\n                  onChange={(e) => setAiPrompt(e.target.value)}\n                  placeholder=\"Ej: Reducir estr\303\251s al instante...\"\n                  className=\"flex-1 text-xs text-slate-200 placeholder:text-slate-600 bg-slate-950 border border-slate-850 rounded-xl px-3 py-2.5 focus:outline-none focus:ring-1 focus:ring-purple-500\"\n                />\n                <button \n                  onClick={launchAiArchitect}\n                  disabled={isAiLoading || !aiPrompt.trim()}\n                  className=\"bg-slate-100 hover:bg-white text-slate-950 px-4 rounded-xl text-xs font-semibold disabled:bg-slate-800 disabled:text-slate-600 shrink-0 transition\"\n                >\n                  {isAiLoading ? <RefreshCw className=\"w-4 h-4 animate-spin\" /> : \'Sintonizar\'}\n                </button>\n              </div>\n\n              {aiError && (\n                <div className=\"text-[10px] text-red-400 bg-red-950/20 border border-red-900/30 p-2 rounded-lg\">\n                  {aiError}\n                </div>\n              )}\n\n              {/* Live Program Explanation readout */}\n              {activeProgramName && (\n                <div className=\"pt-2 border-t border-slate-900\">\n                  <div className=\"text-[10px] font-mono text-slate-200 font-semibold\">{activeProgramName.toUpperCase()}</div>\n                  <p className=\"text-[9.5px] text-slate-400 font-sans leading-relaxed mt-1 italic\">\n                    &ldquo;{aiExplanation}&rdquo;\n                  </p>\n                </div>\n              )}\n            </div>\n            \n            {/* Active stage info if modulated */}\n            {isModulationEnabled && (\n              <div className=\"mt-3 bg-slate-950/50 p-2 rounded-xl border border-slate-900 flex justify-between items-center text-[9px] font-mono text-slate-500\">\n                <span>FASE: {modulationSteps[currentModStep]?.stepName}</span>\n                <span>DESV: PORT {modulationSteps[currentModStep]?.carrierOffset}Hz / PULSO {modulationSteps[currentModStep]?.beatOffset}Hz</span>\n              </div>\n            )}\n          </div>\n\n        </div>\n\n      </div>\n    </div>\n  );\n}\n\n// Simple state calculation helper\nfunction isWithModulationProgress(isModulation: boolean, secs: number) {\n  return isModulation && secs > 0;\n}"
    }
